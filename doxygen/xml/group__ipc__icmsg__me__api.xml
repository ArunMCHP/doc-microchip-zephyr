        <type>void</type>
        <definition>void icmsg_me_reset_ept_cfg</definition>
        <argsstring>(struct icmsg_me_data_t *data, icmsg_me_ept_id_t id)</argsstring>
        <name>icmsg_me_reset_ept_cfg</name>
        <param>
          <type>struct <ref refid="structicmsg__me__data__t" kindref="compound">icmsg_me_data_t</ref> *</type>
          <declname>data</declname>
        </param>
        <param>
          <type><ref refid="group__ipc__icmsg__me__api_1gafb150656560c6e61291bae566ad3990a" kindref="member">icmsg_me_ept_id_t</ref></type>
          <declname>id</declname>
        </param>
        <briefdescription>
<para>Reset endpoint configuration in a selected endpoint slot. </para>
        </briefdescription>
        <detaileddescription>
<para>If handshake fails or an endpoint is disconnected, then configuration slot for given endpoint should be vacated. This function is intended to be used for this purpose.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="inout">data</parametername>

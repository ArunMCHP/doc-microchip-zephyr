        <definition>int w1_match_rom</definition>
        <argsstring>(const struct device *dev, const struct w1_slave_config *config)</argsstring>
        <name>w1_match_rom</name>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *</type>

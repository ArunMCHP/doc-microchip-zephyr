        <name>sensor_channel_mcp9600</name>
        <enumvalue id="group__mcp9600__interface_1ggacdedea96abe329cfee16affa1552578ca47b64269a4af22fd863f3747aa5db98d" prot="public">
          <name>SENSOR_CHAN_MCP9600_COLD_JUNCTION_TEMP</name>
          <initializer>= SENSOR_CHAN_PRIV_START</initializer>
          <briefdescription>
<para>Cold junction (reference) temperature in degrees Celsius. </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> is the integer part of the temperature (°C).</para>
</listitem><listitem><para><computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> is the fractional part (in millionths of a degree). </para>
</listitem></itemizedlist>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__mcp9600__interface_1ggacdedea96abe329cfee16affa1552578cae12b14e6cb9fa10d7b5e0c7ae3c02cb0" prot="public">
          <name>SENSOR_CHAN_MCP9600_HOT_JUNCTION_TEMP</name>
          <briefdescription>
<para>Hot junction (thermocouple tip) temperature in degrees Celsius. </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> is the integer part of the temperature (°C).</para>
</listitem><listitem><para><computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> is the fractional part (in millionths of a degree). </para>
</listitem></itemizedlist>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__mcp9600__interface_1ggacdedea96abe329cfee16affa1552578caf6e4fdc4e7bd9d15e93bed9193559e8a" prot="public">
          <name>SENSOR_CHAN_MCP9600_DELTA_TEMP</name>
          <briefdescription>
<para>Temperature difference (hot junction minus cold junction) in degrees Celsius. </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> is the integer part of the delta temperature (°C).</para>
</listitem><listitem><para><computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> is the fractional part (in millionths of a degree). </para>
</listitem></itemizedlist>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__mcp9600__interface_1ggacdedea96abe329cfee16affa1552578ca50b37a085486804fb64594d4b16938c3" prot="public">
          <name>SENSOR_CHAN_MCP9600_RAW_ADC</name>
          <briefdescription>
<para>Raw ADC value (thermocouple EMF in ADC counts). </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> is the raw 24-bit signed ADC value.</para>
</listitem><listitem><para><computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> is unused (always 0). </para>
</listitem></itemizedlist>
</para>
          </detaileddescription>

        <type>int</type>
        <definition>int bt_bap_unicast_group_create</definition>
        <argsstring>(struct bt_bap_unicast_group_param *param, struct bt_bap_unicast_group **unicast_group)</argsstring>
        <name>bt_bap_unicast_group_create</name>
        <param>
          <type>struct <ref refid="structbt__bap__unicast__group__param" kindref="compound">bt_bap_unicast_group_param</ref> *</type>
          <declname>param</declname>
        </param>
        <param>
          <type>struct <ref refid="structbt__bap__unicast__group" kindref="compound">bt_bap_unicast_group</ref> **</type>
          <declname>unicast_group</declname>
        </param>
        <briefdescription>
<para>Create unicast group. </para>
        </briefdescription>
        <detaileddescription>
<para>Create a new audio unicast group with one or more audio streams as a unicast client. All streams shall share the same framing. All streams in the same direction shall share the same interval and latency (see <ref refid="structbt__bap__qos__cfg" kindref="compound">bt_bap_qos_cfg</ref>).</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">param</parametername>
</parameternamelist>
<parameterdescription>
<para>The unicast group create parameters. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">unicast_group</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the unicast group created.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>Zero on success or (negative) error code otherwise. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/bluetooth/audio/bap.h" line="1704" column="5" declfile="zephyr/bluetooth/audio/bap.h" declline="1704" declcolumn="5"/>

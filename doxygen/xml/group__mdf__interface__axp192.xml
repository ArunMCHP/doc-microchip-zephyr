        </param>
        <param>
          <type>enum <ref refid="drivers_2mfd_2axp192_8h_1ac92e5fa77591e02e49570d1a1c38e249" kindref="member">axp192_gpio_func</ref> *</type>
          <declname>func</declname>
        </param>
        <briefdescription>
<para>Read out current configuration of a specific GPIO pin. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>dev</parametername>
</parameternamelist>
<parameterdescription>
<para>axp192 mfd device </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>gpio</parametername>
</parameternamelist>
<parameterdescription>
<para>GPIO to read configuration from </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>func</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to store current function configuration in. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success </para>
</simplesect>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>-EINVAL</parametername>
</parameternamelist>
<parameterdescription>
<para>if an invalid GPIO number is passed </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-errno</parametername>
</parameternamelist>
<parameterdescription>
<para>in case of any bus error </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>

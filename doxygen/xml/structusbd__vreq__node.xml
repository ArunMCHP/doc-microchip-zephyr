<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><ref refid="group__net__buf_1gacf4e2eba52975ba6728c79274a769d0f" kindref="member">net_buf_add_mem</ref>(buf,<sp/>&amp;webusb_origin_url,</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><ref refid="group__sys-util_1ga3acffbd305ee72dcd4593c0d8af64a4f" kindref="member">MIN</ref>(<ref refid="group__net__buf_1gaecbc6adf16469e3366c88445ea7a553a" kindref="member">net_buf_tailroom</ref>(buf),<sp/></highlight><highlight class="keyword">sizeof</highlight><highlight class="normal">(webusb_origin_url)));</highlight></codeline>

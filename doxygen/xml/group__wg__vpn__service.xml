<parameternamelist>
<parametername>peer_id</parametername>
</parameternamelist>
<parameterdescription>
<para>Peer id returned by <ref refid="group__wg__vpn__service_1ga0e81f216e6856b6d73be215b32d62114" kindref="member">wireguard_peer_add()</ref></para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success, a negative errno otherwise. </para>
</simplesect>
</para>

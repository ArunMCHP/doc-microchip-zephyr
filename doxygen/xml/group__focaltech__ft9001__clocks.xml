  <compounddef id="group__focaltech__ft9001__clocks" kind="group">
    <compoundname>focaltech_ft9001_clocks</compoundname>
    <title>FocalTech FT9001 clock identifiers</title>
    <innerfile refid="focaltech__ft9001__clocks_8h">focaltech_ft9001_clocks.h</innerfile>
    <briefdescription>
<para>Clock identifiers for FocalTech FT9001. </para>
    </briefdescription>
    <detaileddescription>
<para>Clock identifiers follow the naming convention: <computeroutput>FOCALTECH_CLOCK_&lt;PERIPHERAL&gt;</computeroutput> </para>
<para>For example, <computeroutput>FOCALTECH_CLOCK_SPI1</computeroutput> identifies the clock gate for <computeroutput>SPI1</computeroutput>.</para>
<para>Valid peripherals (grouped by clock gate control register):</para>
<para><itemizedlist>
<listitem><para><bold>MULTICGCR</bold>: <computeroutput>OTP_AHB</computeroutput>, <computeroutput>MCC</computeroutput>, <computeroutput>MCCADR</computeroutput>, <computeroutput>ADC</computeroutput>, <computeroutput>MESH</computeroutput>, <computeroutput>TC</computeroutput>, <computeroutput>CLKOUT</computeroutput>, <computeroutput>KEY_CTRL</computeroutput>, <computeroutput>CCM_RESET</computeroutput>, <computeroutput>OTP_IPS</computeroutput>, <computeroutput>CPM_IPS</computeroutput>, <computeroutput>TRACE</computeroutput>, <computeroutput>I2S_M</computeroutput>, <computeroutput>I2S_S</computeroutput>, <computeroutput>CRC0</computeroutput>, <computeroutput>CRC1</computeroutput> </para>
</listitem><listitem><para><bold>SYSCGCR</bold>: <computeroutput>SSISLV1</computeroutput>, <computeroutput>DMAC1</computeroutput>, <computeroutput>DMAC2</computeroutput>, <computeroutput>AHB2_MUX</computeroutput>, <computeroutput>PXLP1_AHB</computeroutput>, <computeroutput>PXLP2_AHB</computeroutput>, <computeroutput>SRAMD</computeroutput>, <computeroutput>SRAM0</computeroutput>, <computeroutput>SRAM1</computeroutput>, <computeroutput>SRAM2</computeroutput>, <computeroutput>SRAM3_4</computeroutput>, <computeroutput>SSI4</computeroutput>, <computeroutput>SSI5</computeroutput>, <computeroutput>SSI6</computeroutput> </para>
</listitem><listitem><para><bold>AHB3CGCR</bold>: <computeroutput>ROM</computeroutput>, <computeroutput>ROM_OTP_MUX</computeroutput>, <computeroutput>AHB3_MUX</computeroutput>, <computeroutput>USBC</computeroutput>, <computeroutput>PXLP1_APB</computeroutput>, <computeroutput>PXLP2_APB</computeroutput>, <computeroutput>I2S1</computeroutput>, <computeroutput>I2S2</computeroutput> </para>
</listitem><listitem><para><bold>ARITHCGCR</bold>: <computeroutput>AES</computeroutput>, <computeroutput>SM4</computeroutput>, <computeroutput>RF_AES_SM4</computeroutput>, <computeroutput>CRYPTO</computeroutput>, <computeroutput>SHA</computeroutput>, <computeroutput>EDMAC0</computeroutput>, <computeroutput>DES</computeroutput>, <computeroutput>ZUC</computeroutput>, <computeroutput>AHB2MLB</computeroutput>, <computeroutput>AHB2IPS2</computeroutput>, <computeroutput>TRNG</computeroutput> </para>
</listitem><listitem><para><bold>IPSCGCR</bold>: <computeroutput>IO_CTRL</computeroutput>, <computeroutput>WDT</computeroutput>, <computeroutput>RTC</computeroutput>, <computeroutput>PIT1</computeroutput>, <computeroutput>PIT2</computeroutput>, <computeroutput>USI1</computeroutput>, <computeroutput>EDMAC1</computeroutput>, <computeroutput>SPI1</computeroutput>, <computeroutput>SPI2</computeroutput>, <computeroutput>SPI3</computeroutput>, <computeroutput>SCI1</computeroutput>, <computeroutput>SCI2</computeroutput>, <computeroutput>USI2</computeroutput>, <computeroutput>CAN1</computeroutput>, <computeroutput>I2C1</computeroutput>, <computeroutput>PWM0</computeroutput>, <computeroutput>I2C2</computeroutput>, <computeroutput>CAN2</computeroutput>, <computeroutput>SCI3</computeroutput>, <computeroutput>QADC</computeroutput>, <computeroutput>DAC</computeroutput>, <computeroutput>MCC_IPS</computeroutput>, <computeroutput>PWMT1</computeroutput>, <computeroutput>LD</computeroutput>, <computeroutput>PWMT2</computeroutput>, <computeroutput>PGD</computeroutput>, <computeroutput>SEC_DET</computeroutput>, <computeroutput>PCI</computeroutput>, <computeroutput>PMURTC</computeroutput>, <computeroutput>AHB2IPS</computeroutput>, <computeroutput>PWMT3</computeroutput> </para>
</listitem><listitem><para><bold>EPORTCGCR</bold>: <computeroutput>EPORT0</computeroutput>, <computeroutput>EPORT1</computeroutput>, <computeroutput>EPORT2</computeroutput>, <computeroutput>EPORT3</computeroutput>, <computeroutput>EPORT4</computeroutput>, <computeroutput>EPORT5</computeroutput>, <computeroutput>EPORT6</computeroutput>, <computeroutput>EPORT7</computeroutput>, <computeroutput>ACMP1</computeroutput>, <computeroutput>ACMP2</computeroutput> </para>
</listitem></itemizedlist>
</para>

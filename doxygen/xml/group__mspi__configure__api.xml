      <memberdef kind="function" id="group__mspi__configure__api_1gaa3c1eae8b3000c9bafcc26f14a8beb8b" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int mspi_dev_config</definition>
        <argsstring>(const struct device *controller, const struct mspi_dev_id *dev_id, const enum mspi_dev_cfg_mask param_mask, const struct mspi_dev_cfg *cfg)</argsstring>
        <name>mspi_dev_config</name>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *</type>
          <declname>controller</declname>
        </param>
        <param>

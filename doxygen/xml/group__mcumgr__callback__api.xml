</parameternamelist>
<parameterdescription>
<para><ref refid="group__mcumgr__mgmt__api_1gae06a618f492f18e856742b4affab80dd" kindref="member">mcumgr_op_t</ref>. </para>
</parameterdescription>
</parameteritem>

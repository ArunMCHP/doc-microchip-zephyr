        <definition>int mfd_bd8lb600fs_get_output_diagnostics</definition>
        <argsstring>(const struct device *dev, uint32_t *old, uint32_t *ocp_or_tsd)</argsstring>
        <name>mfd_bd8lb600fs_get_output_diagnostics</name>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *</type>
          <declname>dev</declname>
        </param>
        <param>

      <memberdef kind="typedef" id="group__mcumgr__transport__smp_1gaacb9495e395e3b763eaca70546dc9555" prot="public" static="no">
        <type><ref refid="stdbool_8h_1abb452686968e48b67397da5f97445f5b" kindref="member">bool</ref>(*</type>
        <definition>smp_transport_query_valid_check_fn</definition>
        <argsstring>)(struct net_buf *nb, void *arg)</argsstring>
        <name>smp_transport_query_valid_check_fn</name>
        <briefdescription>
<para>Function for checking if queued data is still valid. </para>
        </briefdescription>
        <detaileddescription>
<para>This function is used to check if queued SMP data is still valid e.g. on a remote device disconnecting, this is triggered when <ref refid="group__mcumgr__transport__smp_1ga87ccc623b5907d7d65b24ed99bd57ec5" kindref="member">smp_rx_remove_invalid()</ref> is called.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>nb</parametername>
</parameternamelist>
<parameterdescription>
<para>net buf containing queued request. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>arg</parametername>
</parameternamelist>
<parameterdescription>
<para>Argument provided when calling <ref refid="group__mcumgr__transport__smp_1ga87ccc623b5907d7d65b24ed99bd57ec5" kindref="member">smp_rx_remove_invalid()</ref> function.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>false if data is no longer valid/should be freed, true otherwise. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

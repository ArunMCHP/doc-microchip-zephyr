        <param>
          <type>struct modem_cmux *</type>
          <declname>cmux</declname>
        </param>
        <briefdescription>
<para>Connect CMUX instance asynchronously. </para>
        </briefdescription>
        <detaileddescription>
<para>This will send a CMUX connect request to target on the serial bus. If successful, DLCI channels can be now be opened using <ref refid="group__modem__pipe_1ga7521ac0aeda8027c47741237e8312bf0" kindref="member">modem_pipe_open()</ref>.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>cmux</parametername>
</parameternamelist>
<parameterdescription>
<para>CMUX instance</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="note"><para>When connected, the bus pipe must not be used directly </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/modem/cmux.h" line="285" column="5" declfile="zephyr/modem/cmux.h" declline="285" declcolumn="5"/>

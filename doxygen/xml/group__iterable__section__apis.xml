</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">secname</parametername>
</parameternamelist>
<parameterdescription>
<para>name of output section </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>

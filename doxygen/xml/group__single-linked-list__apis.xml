</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>__sn</parametername>
</parameternamelist>
<parameterdescription>
<para>A sys_snode_t pointer to peek each node of the list </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>

      <memberdef kind="function" id="group__ipc__icmsg__api_1ga13b8669034ee51044df7f0623907c03b" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int icmsg_send</definition>
        <argsstring>(const struct icmsg_config_t *conf, struct icmsg_data_t *dev_data, const void *msg, size_t len)</argsstring>
        <name>icmsg_send</name>
        <param>
          <type>const struct <ref refid="structicmsg__config__t" kindref="compound">icmsg_config_t</ref> *</type>
          <declname>conf</declname>
        </param>
        <param>
          <type>struct <ref refid="structicmsg__data__t" kindref="compound">icmsg_data_t</ref> *</type>
          <declname>dev_data</declname>
        </param>
        <param>
          <type>const void *</type>
          <declname>msg</declname>
        </param>
        <param>
          <type><ref refid="retained__mem_8h_1a36713c339c3c5ec6d6bd481480bdb6f9" kindref="member">size_t</ref></type>
          <declname>len</declname>
        </param>
        <briefdescription>
<para>Send a message to the remote icmsg instance. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">conf</parametername>
</parameternamelist>
<parameterdescription>
<para>Structure containing configuration parameters for the icmsg instance. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="inout">dev_data</parametername>
</parameternamelist>
<parameterdescription>
<para>Structure containing run-time data used by the icmsg instance. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">msg</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to a buffer containing data to send. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">len</parametername>
</parameternamelist>
<parameterdescription>
<para>Size of data in the <computeroutput>msg</computeroutput> buffer.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>Number</parametername>
</parameternamelist>
<parameterdescription>
<para>of sent bytes. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EBUSY</parametername>
</parameternamelist>
<parameterdescription>
<para>when the instance has not finished handshake with the remote instance. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-ENODATA</parametername>
</parameternamelist>
<parameterdescription>
<para>when the requested data to send is empty. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EBADMSG</parametername>
</parameternamelist>
<parameterdescription>
<para>when the requested data to send is too big. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-ENOBUFS</parametername>
</parameternamelist>
<parameterdescription>
<para>when there are no TX buffers available. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>other</parametername>
</parameternamelist>
<parameterdescription>
<para>errno codes from dependent modules. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>

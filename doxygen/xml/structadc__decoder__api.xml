      <memberdef kind="variable" id="structadc__decoder__api_1acdbfeda4bfbb7afd77fa86be27c3e333" prot="public" static="no" mutable="no">
        <type>int(*</type>
        <definition>int(* adc_decoder_api::decode) (const uint8_t *buffer, uint32_t channel, uint32_t *fit, uint16_t max_count, void *data_out)</definition>
        <argsstring>)(const uint8_t *buffer, uint32_t channel, uint32_t *fit, uint16_t max_count, void *data_out)</argsstring>
        <name>decode</name>
        <qualifiedname>adc_decoder_api::decode</qualifiedname>
        <briefdescription>
<para>Decode up to <computeroutput>max_count</computeroutput> samples from the buffer. </para>
        </briefdescription>
        <detaileddescription>
<para>Decode samples of channel across multiple frames. If there exist multiple instances of the same channel, <computeroutput>channel_index</computeroutput> is used to differentiate them.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">buffer</parametername>
</parameternamelist>
<parameterdescription>
<para>The buffer provided on the <ref refid="group__rtio" kindref="compound">RTIO</ref> context </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">channel</parametername>
</parameternamelist>
<parameterdescription>
<para>The channel to decode </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="inout">fit</parametername>
</parameternamelist>
<parameterdescription>
<para>The current frame iterator </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">max_count</parametername>
</parameternamelist>
<parameterdescription>
<para>The maximum number of channels to decode. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">data_out</parametername>
</parameternamelist>
<parameterdescription>
<para>The decoded data </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 no more samples to decode </para>
</simplesect>
<simplesect kind="return"><para>&gt;0 the number of decoded frames </para>
</simplesect>
<simplesect kind="return"><para>&lt;0 on error </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

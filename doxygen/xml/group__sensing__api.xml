        <type>int</type>
        <definition>int sensing_get_sensors</definition>
        <argsstring>(int *num_sensors, const struct sensing_sensor_info **info)</argsstring>
        <name>sensing_get_sensors</name>
        <param>
          <type>int *</type>
          <declname>num_sensors</declname>
        </param>
        <param>
          <type>const struct <ref refid="structsensing__sensor__info" kindref="compound">sensing_sensor_info</ref> **</type>
          <declname>info</declname>
        </param>
        <briefdescription>
<para>Get all supported sensor instances&apos; information. </para>
        </briefdescription>
        <detaileddescription>
<para>This API just returns read only information of sensor instances, pointer info will directly point to internal buffer, no need for caller to allocate buffer, no side effect to sensor instances.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>num_sensors</parametername>
</parameternamelist>
<parameterdescription>
<para>Get number of sensor instances. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>info</parametername>
</parameternamelist>
<parameterdescription>
<para>For receiving sensor instances&apos; information array pointer. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success or negative error value on failure. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

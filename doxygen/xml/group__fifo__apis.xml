        <name>k_fifo_cancel_wait</name>
        <param><defname>fifo</defname></param>
        <initializer>	({ \
	<ref refid="group__subsys__tracing__macros_1ga4ce3846263099a197c043f25ebe4a253" kindref="member">SYS_PORT_TRACING_OBJ_FUNC_ENTER</ref>(<ref refid="structk__fifo" kindref="compound">k_fifo</ref>, cancel_wait, fifo); \

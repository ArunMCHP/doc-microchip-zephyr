        <param><defname>node_id</defname></param>
        <param><defname>idx</defname></param>
        <initializer>	{                                                                                          \
		.dev = <ref refid="group__device__model_1ga9a65996ce21f43acb7db061e23b48ec7" kindref="member">DEVICE_DT_GET</ref>(<ref refid="group__devicetree-hwspinlock_1ga73bf7f0129392cba4c6ba13bf59b86b8" kindref="member">DT_HWSPINLOCK_CTRL_BY_IDX</ref>(node_id, idx)),                     \

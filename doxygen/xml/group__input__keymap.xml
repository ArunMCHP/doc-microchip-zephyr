      <memberdef kind="define" id="group__input__keymap_1gafd3fd33c07ccb96c0c88c1a8d340fee3" prot="public" static="no">
        <name>MATRIX_ROW</name>
        <param><defname>keymap_entry</defname></param>
        <initializer>(((keymap_entry) &gt;&gt; 24) &amp; 0xff)</initializer>
        <briefdescription>
<para>Extract the row index from a keymap entry. </para>
        </briefdescription>
        <detaileddescription>
<para>This macro extracts the row index from a 32-bit keymap entry. The row index is stored in bits 24-31 of the keymap entry.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>keymap_entry</parametername>
</parameternamelist>
<parameterdescription>
<para>The 32-bit keymap entry value. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>The row index (0-255) extracted from the keymap entry. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

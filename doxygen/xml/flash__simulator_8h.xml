      <memberdef kind="typedef" id="flash__simulator_8h_1a24b9919bf5776683d1890c46ed961bd5" prot="public" static="no">
        <type>int(*</type>
        <definition>typedef int(* flash_simulator_erase_unit_cb_t) (const struct device *dev, off_t unit_offset)</definition>
        <argsstring>)(const struct device *dev, off_t unit_offset)</argsstring>
        <name>flash_simulator_erase_unit_cb_t</name>
        <briefdescription>
<para>Flash simulator erase unit callback type. </para>
        </briefdescription>
        <detaileddescription>
<para>Callback used to overwrite unit erase operation. The callback gets the unit offset as the parameter. The offset is the same offset passed to the flash erase. The callback must return 0 in case of success or negative value in case of error.</para>
<para><simplesect kind="note"><para>If this callback is set, the flash simulator driver will not perform any erase operation by itself.</para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>dev</parametername>
</parameternamelist>
<parameterdescription>
<para>Flash simulator device pointer. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>unit_offset</parametername>
</parameternamelist>
<parameterdescription>
<para>Offset within the flash simulator memory. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 in case of success or negative value in case of error. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/drivers/flash/flash_simulator.h" line="70" column="9" bodyfile="zephyr/drivers/flash/flash_simulator.h" bodystart="70" bodyend="-1"/>

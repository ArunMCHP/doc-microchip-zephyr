      <memberdef kind="function" id="group__bt__gmap_1gab54963e226753d44085a7d1f5dccdef6" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int bt_gmap_discover</definition>
        <argsstring>(struct bt_conn *conn)</argsstring>
        <name>bt_gmap_discover</name>
        <param>
          <type>struct <ref refid="structbt__conn" kindref="compound">bt_conn</ref> *</type>
          <declname>conn</declname>
        </param>
        <briefdescription>
<para>Discover Gaming Service on a remote device. </para>
        </briefdescription>
        <detaileddescription>
<para>Procedure to find a Gaming Service on a server identified by <computeroutput>conn</computeroutput>. The <ref refid="structbt__gmap__cb_1a72c25ae277e04d419f41733d0b11aefc" kindref="member">bt_gmap_cb::discover</ref> callback is called when the discovery procedure completes of fails. On discovery success the callback contains information about the remote device.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>conn</parametername>
</parameternamelist>
<parameterdescription>
<para>Bluetooth connection object.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>-EINVAL</parametername>
</parameternamelist>
<parameterdescription>
<para>if <computeroutput>conn</computeroutput> is NULL </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EBUSY</parametername>
</parameternamelist>
<parameterdescription>
<para>if discovery is already in progress for <computeroutput>conn</computeroutput> </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-ENOEXEC</parametername>
</parameternamelist>
<parameterdescription>
<para>if discovery failed to initiate </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>on success </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

</parameternamelist>
<parameterdescription>
<para>A previously initialized builder with payload. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>der_key</parametername>
</parameternamelist>
<parameterdescription>
<para>Private key to use in DER format. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>der_key_len</parametername>
</parameternamelist>
<parameterdescription>
<para>Size of the private key in bytes.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>

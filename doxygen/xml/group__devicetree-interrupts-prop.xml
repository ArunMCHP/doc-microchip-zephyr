      <memberdef kind="define" id="group__devicetree-interrupts-prop_1ga7b63eb05db40d7b95ccb62a9fd1f4404" prot="public" static="no">
        <name>DT_NUM_NODELABELS</name>
        <param><defname>node_id</defname></param>
        <initializer>DT_CAT(node_id, _NODELABEL_NUM)</initializer>
        <briefdescription>
<para>Get the number of node labels that a node has. </para>
        </briefdescription>
        <detaileddescription>
<para>Example devicetree fragment:</para>
<para><programlisting filename=".dts"><codeline><highlight class="normal">/<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>foo<sp/>{};</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>bar:<sp/>bar@1000<sp/>{};</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>baz:<sp/>baz2:<sp/>baz@2000<sp/>{};</highlight></codeline>
<codeline><highlight class="normal">};</highlight></codeline>
</programlisting></para>
<para>Example usage:</para>
<para><programlisting filename=".c"><codeline><highlight class="normal"><ref refid="group__devicetree-interrupts-prop_1ga7b63eb05db40d7b95ccb62a9fd1f4404" kindref="member">DT_NUM_NODELABELS</ref>(<ref refid="group__devicetree-generic-id_1ga015b4819473797982e83cae497697086" kindref="member">DT_PATH</ref>(foo))<sp/><sp/><sp/><sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>0</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="group__devicetree-interrupts-prop_1ga7b63eb05db40d7b95ccb62a9fd1f4404" kindref="member">DT_NUM_NODELABELS</ref>(<ref refid="group__devicetree-generic-id_1gab7d23294a6bf7fd44a98b48ec47d8a79" kindref="member">DT_NODELABEL</ref>(bar))<sp/></highlight><highlight class="comment">//<sp/>1</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="group__devicetree-interrupts-prop_1ga7b63eb05db40d7b95ccb62a9fd1f4404" kindref="member">DT_NUM_NODELABELS</ref>(<ref refid="group__devicetree-generic-id_1gab7d23294a6bf7fd44a98b48ec47d8a79" kindref="member">DT_NODELABEL</ref>(baz))<sp/></highlight><highlight class="comment">//<sp/>2</highlight></codeline>
</programlisting></para>
<para><parameterlist kind="param"><parameteritem>

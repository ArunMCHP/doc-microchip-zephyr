        <argsstring>(int socket, struct net_in_addr *ip)</argsstring>
        <name>net_latmon_connect</name>
        <param>
          <type>int</type>
          <declname>socket</declname>
        </param>
        <param>
          <type>struct <ref refid="structnet__in__addr" kindref="compound">net_in_addr</ref> *</type>
          <declname>ip</declname>
        </param>
        <briefdescription>
<para>Wait for a connection from a Latmus client. </para>
        </briefdescription>
        <detaileddescription>
<para>This function blocks until a Latmus client connects to the specified socket. Once connected, the client&apos;s IP address is stored in the provided <computeroutput>ip</computeroutput> structure.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>socket</parametername>
</parameternamelist>
<parameterdescription>
<para>A valid socket descriptor for listening. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>ip</parametername>
</parameternamelist>
<parameterdescription>
<para>The client&apos;s IP address. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>A valid client socket descriptor connected to latmus on success, negative errno code on failure. </para>
</simplesect>
</para>
        </detaileddescription>

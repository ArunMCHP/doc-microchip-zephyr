    <sectiondef kind="func">
      <memberdef kind="function" id="group__bt__hci__api_1gac744c98801cea5afd13d6774154e71c8" prot="public" static="yes" const="no" explicit="no" inline="yes" virt="non-virtual">
        <type>int</type>
        <definition>static int bt_hci_open</definition>
        <argsstring>(const struct device *dev, bt_hci_recv_t recv)</argsstring>
        <name>bt_hci_open</name>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *</type>
          <declname>dev</declname>
        </param>
        <param>
          <type><ref refid="group__bt__hci__api__backend_1ga79b12569871b2b6c8420c245e9505aed" kindref="member">bt_hci_recv_t</ref></type>
          <declname>recv</declname>
        </param>
        <briefdescription>
<para>Open the HCI transport. </para>
        </briefdescription>
        <detaileddescription>
<para>Opens the HCI transport for operation. This function must not return until the transport is ready for operation, meaning it is safe to start calling the <ref refid="posix_2sys_2socket_8h_1a16485de18b1ec93572e5d74b4a04e42f" kindref="member">send()</ref> handler.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>dev</parametername>
</parameternamelist>
<parameterdescription>
<para>HCI device </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>recv</parametername>
</parameternamelist>
<parameterdescription>
<para>This is callback through which the HCI driver provides the host with data from the controller. The callback is expected to be called from thread context.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success or negative POSIX error number on failure. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/drivers/bluetooth.h" line="182" column="19" bodyfile="zephyr/drivers/bluetooth.h" bodystart="182" bodyend="185"/>
      </memberdef>
      <memberdef kind="function" id="group__bt__hci__api_1gad187f0aff959a4756b281aa33d1b4394" prot="public" static="yes" const="no" explicit="no" inline="yes" virt="non-virtual">
        <type>int</type>
        <definition>static int bt_hci_close</definition>
        <argsstring>(const struct device *dev)</argsstring>
        <name>bt_hci_close</name>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *</type>
          <declname>dev</declname>
        </param>
        <briefdescription>
<para>Close the HCI transport. </para>
        </briefdescription>
        <detaileddescription>
<para>Closes the HCI transport. This function must not return until the transport is closed.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>dev</parametername>
</parameternamelist>
<parameterdescription>
<para>HCI device</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success or negative POSIX error number on failure. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>

        </param>
        <briefdescription>
<para>This function puts data to a &quot;file&quot; on the remote server. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>client</parametername>
</parameternamelist>
<parameterdescription>

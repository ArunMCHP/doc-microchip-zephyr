      <memberdef kind="define" id="group__llext__symbols_1ga2e05a6082a3ee50fbc74e14a48056626" prot="public" static="no">
        <name>LL_EXTENSION_SYMBOL</name>
        <param><defname>x</defname></param>
        <initializer>Z_LL_EXTENSION_SYMBOL_NAMED(x, x)</initializer>
        <briefdescription>
<para>Exports a symbol from an extension to the base image. </para>
        </briefdescription>
        <detaileddescription>
<para>This macro can be used in extensions to add a symbol (function or object) to the extension&apos;s exported symbol table, so that it may be referenced by the base image.</para>
<para>When not building an extension, this macro is a no-op.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>x</parametername>
</parameternamelist>
<parameterdescription>
<para>Extension symbol to export to the base image </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/llext/symbol.h" line="183" column="9" bodyfile="zephyr/llext/symbol.h" bodystart="183" bodyend="-1"/>
      </memberdef>
      <memberdef kind="define" id="group__llext__symbols_1ga9822b90952597e6acd993999a7228aa1" prot="public" static="no">
        <name>EXPORT_SYMBOL_NAMED</name>
        <param><defname>sym_ident</defname></param>
        <param><defname>sym_name</defname></param>
        <initializer>	Z_EXPORT_SYMBOL_NAMED_IN_GROUP(UNASSIGNED, sym_ident, sym_name)</initializer>
        <briefdescription>
<para>Export a constant symbol from the current build with a custom name. </para>
        </briefdescription>
        <detaileddescription>
<para>Version of <ref refid="group__llext__symbols_1ga0188531646d69e784eccf85bd4fb34aa" kindref="member">EXPORT_SYMBOL</ref> that allows the user to specify a custom name for the exported symbol. The symbol is part of the UNASSIGNED group.</para>
<para>When <computeroutput>CONFIG_LLEXT</computeroutput> is not enabled, this macro is a no-op.</para>
<para>When <computeroutput>CONFIG_LLEXT_EXPORT_SYMBOL_GROUP_UNASSIGNED</computeroutput> is not enabled, this macro is a no-op.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>sym_ident</parametername>
</parameternamelist>
<parameterdescription>
<para>Symbol to export </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>sym_name</parametername>
</parameternamelist>
<parameterdescription>
<para>Name associated with the symbol </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/llext/symbol.h" line="239" column="9" bodyfile="zephyr/llext/symbol.h" bodystart="239" bodyend="240"/>
      </memberdef>
      <memberdef kind="define" id="group__llext__symbols_1ga0188531646d69e784eccf85bd4fb34aa" prot="public" static="no">
        <name>EXPORT_SYMBOL</name>
        <param><defname>x</defname></param>
        <initializer><ref refid="group__llext__symbols_1ga9822b90952597e6acd993999a7228aa1" kindref="member">EXPORT_SYMBOL_NAMED</ref>(x, x)</initializer>
        <briefdescription>
<para>Export a constant symbol from the current build. </para>
        </briefdescription>
        <detaileddescription>
<para>Takes a symbol (function or object) by symbolic name and adds the name and address of the symbol to a table of symbols that may be referenced by extensions or by the base image, depending on the current build type. The symbol is part of the UNASSIGNED group.</para>
<para>When <computeroutput>CONFIG_LLEXT</computeroutput> is not enabled, this macro is a no-op.</para>
<para>When <computeroutput>CONFIG_LLEXT_EXPORT_SYMBOL_GROUP_UNASSIGNED</computeroutput> is not enabled, this macro is a no-op.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>x</parametername>
</parameternamelist>
<parameterdescription>
<para>Symbol to export </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/llext/symbol.h" line="257" column="9" bodyfile="zephyr/llext/symbol.h" bodystart="257" bodyend="-1"/>
      </memberdef>

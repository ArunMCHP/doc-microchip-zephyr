      <memberdef kind="function" id="group__bindesc__read_1ga724d940fecd648523c3d3bd840785498" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int bindesc_open_flash</definition>
        <argsstring>(struct bindesc_handle *handle, size_t offset, const struct device *flash_device)</argsstring>
        <name>bindesc_open_flash</name>
        <param>
          <type>struct <ref refid="structbindesc__handle" kindref="compound">bindesc_handle</ref> *</type>
          <declname>handle</declname>
        </param>
        <param>
          <type><ref refid="retained__mem_8h_1a36713c339c3c5ec6d6bd481480bdb6f9" kindref="member">size_t</ref></type>
          <declname>offset</declname>
        </param>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *</type>
          <declname>flash_device</declname>
        </param>
        <briefdescription>
<para>Open an image&apos;s binary descriptors for reading, from flash. </para>
        </briefdescription>
        <detaileddescription>
<para>Initializes a bindesc handle for subsequent calls to bindesc API. As opposed to reading bindesc from RAM or memory mapped flash, this backend requires reading the data from flash to an internal buffer using the flash API</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="out">handle</parametername>
</parameternamelist>
<parameterdescription>
<para>Bindesc handle to be given to subsequent calls </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>offset</parametername>
</parameternamelist>
<parameterdescription>
<para>The offset from the beginning of the flash that the bindesc magic can be found at </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>flash_device</parametername>
</parameternamelist>
<parameterdescription>
<para>Flash device to read descriptors from</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="attention"><para>Available only when the following Kconfig option is enabled: <computeroutput>CONFIG_BINDESC_READ_FLASH</computeroutput>.</para>
</simplesect>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>On success </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-ENOENT</parametername>
</parameternamelist>
<parameterdescription>
<para>If no bindesc magic was found at the given offset </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/bindesc.h" line="432" column="5" declfile="zephyr/bindesc.h" declline="432" declcolumn="5"/>

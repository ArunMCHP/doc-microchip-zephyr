        <type>int(*</type>
        <definition>int(* adc_decoder_api::get_frame_count) (const uint8_t *buffer, uint32_t channel, uint16_t *frame_count)</definition>
        <argsstring>)(const uint8_t *buffer, uint32_t channel, uint16_t *frame_count)</argsstring>
        <name>get_frame_count</name>
        <qualifiedname>adc_decoder_api::get_frame_count</qualifiedname>
        <briefdescription>
<para>Get the number of frames in the current buffer. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">buffer</parametername>
</parameternamelist>
<parameterdescription>
<para>The buffer provided on the <ref refid="group__rtio" kindref="compound">RTIO</ref> context. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">channel</parametername>
</parameternamelist>
<parameterdescription>
<para>The channel to get the count for </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">frame_count</parametername>
</parameternamelist>
<parameterdescription>
<para>The number of frames on the buffer (at least 1) </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success </para>
</simplesect>
<simplesect kind="return"><para>-ENOTSUP if the channel/channel_idx aren&apos;t found </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>

        <briefdescription>
<para>Read an entry from the file system. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>fs</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to file system </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>

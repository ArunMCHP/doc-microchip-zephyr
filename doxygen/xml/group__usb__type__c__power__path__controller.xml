<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>if request was successfully sent </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EIO</parametername>
</parameternamelist>
<parameterdescription>
<para>if I2C communication failed </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-ENOSYS</parametername>
</parameternamelist>
<parameterdescription>
<para>if this function is not supported by the driver </para>

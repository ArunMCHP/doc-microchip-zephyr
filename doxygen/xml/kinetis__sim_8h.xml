      </memberdef>
      <memberdef kind="define" id="kinetis__sim_8h_1a9133025af86dcbbaa0a9794433e927c8" prot="public" static="no">
        <name>KINETIS_SIM_CLOCK_MUX</name>
        <param><defname>name</defname></param>
        <param><defname>offset</defname></param>
        <param><defname>bits</defname></param>
        <param><defname>mux_shift</defname></param>
        <param><defname>mux_val</defname></param>
        <initializer>	KINETIS_SIM_CLOCK_ID_MUX(name, offset, bits, mux_shift, mux_val) offset bits</initializer>
        <briefdescription>
<para>Build a 3-cell SIM clock specifier with mux configuration. </para>
        </briefdescription>
        <detaileddescription>
<para>Like KINETIS_SIM_CLOCK but also encodes the mux register field and value needed for <ref refid="group__clock__control__interface_1gaf5e4b13798955fcc891c080b9967ab06" kindref="member">clock_control_configure()</ref> support.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>name</parametername>
</parameternamelist>
<parameterdescription>
<para>Clock name selector (KINETIS_SIM_*_CLK) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>offset</parametername>
</parameternamelist>
<parameterdescription>
<para>Gate register offset </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>bits</parametername>
</parameternamelist>
<parameterdescription>
<para>Gate bit index (0..31) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>mux_shift</parametername>
</parameternamelist>
<parameterdescription>
<para>Bit shift of the mux field in the mux register (e.g. SOPT2) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>mux_val</parametername>
</parameternamelist>
<parameterdescription>
<para>Value to write into the mux field </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>

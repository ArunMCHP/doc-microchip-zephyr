          <briefdescription>
<para>Interrupt polarity (reserved for future use). </para>
          </briefdescription>
          <detaileddescription>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__max30210__interface_1ggaa488348f55e1d329ef0b671cdc3b6596af2832c156b33eb492a6b4ccfbfe04962" prot="public">
          <name>SENSOR_ATTR_MAX30210_CONTINUOUS_CONVERSION_MODE</name>
          <briefdescription>
<para>Enable continuous conversion mode. </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> and <computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> are ignored. </para>
</listitem></itemizedlist>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__max30210__interface_1ggaa488348f55e1d329ef0b671cdc3b6596ad8006179be6db28b7b7c94d29cfacaaf" prot="public">
          <name>SENSOR_ATTR_MAX30210_TEMP_INC_FAST_THRESH</name>
          <briefdescription>
<para>Temperature sample-to-sample increment threshold (°C) for fast-change detection. </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> is the integer part of the threshold (°C).</para>
</listitem><listitem><para><computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> is the fractional part (in millionths of a degree). </para>
</listitem></itemizedlist>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__max30210__interface_1ggaa488348f55e1d329ef0b671cdc3b6596ad0891ab0e7d3b4e5471076ef110a1484" prot="public">
          <name>SENSOR_ATTR_MAX30210_TEMP_DEC_FAST_THRESH</name>
          <briefdescription>
<para>Temperature sample-to-sample decrement threshold (°C) for fast-change detection. </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> is the integer part of the threshold (°C).</para>
</listitem><listitem><para><computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> is the fractional part (in millionths of a degree). Must be a multiple of 0.005 °C. </para>
</listitem></itemizedlist>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__max30210__interface_1ggaa488348f55e1d329ef0b671cdc3b6596ab8bf3efd154661c296343d895c2ee0c1" prot="public">
          <name>SENSOR_ATTR_MAX30210_RATE_CHG_FILTER</name>
          <briefdescription>
<para>Rate-of-change filter coefficient (0-7). </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> is the filter value.</para>
</listitem><listitem><para><computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> is unused (always 0). </para>
</listitem></itemizedlist>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__max30210__interface_1ggaa488348f55e1d329ef0b671cdc3b6596a5b82942e05aa324d8a376a3308e33154" prot="public">
          <name>SENSOR_ATTR_MAX30210_HI_TRIP_COUNT</name>
          <briefdescription>
<para>High-temperature alarm trip count (1-4). </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> is the number of consecutive samples above threshold.</para>
</listitem><listitem><para><computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> is unused (always 0). </para>
</listitem></itemizedlist>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__max30210__interface_1ggaa488348f55e1d329ef0b671cdc3b6596a1421ffa5dc618242b9476bf9b9d2477c" prot="public">
          <name>SENSOR_ATTR_MAX30210_LO_TRIP_COUNT</name>
          <briefdescription>
<para>Low-temperature alarm trip count (1-4). </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> is the number of consecutive samples below threshold.</para>
</listitem><listitem><para><computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> is unused (always 0). </para>
</listitem></itemizedlist>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__max30210__interface_1ggaa488348f55e1d329ef0b671cdc3b6596a49a1d9f8c7cfd048f5d6f6e8e557f80f" prot="public">
          <name>SENSOR_ATTR_MAX30210_HI_TRIP_COUNT_RESET</name>
          <briefdescription>
<para>Reset high-temperature trip counter. </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> is 0 to leave counter unchanged, 1 to reset.</para>
</listitem><listitem><para><computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> is unused (always 0). </para>
</listitem></itemizedlist>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__max30210__interface_1ggaa488348f55e1d329ef0b671cdc3b6596ac17544d14818e04c202b2b7b7c48a4a6" prot="public">
          <name>SENSOR_ATTR_MAX30210_LO_TRIP_COUNT_RESET</name>
          <briefdescription>
<para>Reset low-temperature trip counter. </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> is 0 to leave counter unchanged, 1 to reset.</para>
</listitem><listitem><para><computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> is unused (always 0). </para>
</listitem></itemizedlist>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__max30210__interface_1ggaa488348f55e1d329ef0b671cdc3b6596a8afa486799cc1a610c99ad827a2fa187" prot="public">
          <name>SENSOR_ATTR_MAX30210_HI_NON_CONSECUTIVE_MODE</name>
          <briefdescription>
<para>High-temperature alarm non-consecutive mode. </para>
          </briefdescription>
          <detaileddescription>
<para><itemizedlist>
<listitem><para><computeroutput><ref refid="structsensor__value_1af21dddb084da4c42a7e77b48edf26fbe" kindref="member">sensor_value.val1</ref></computeroutput> is 0 for consecutive, 1 for non-consecutive.</para>
</listitem><listitem><para><computeroutput><ref refid="structsensor__value_1a91f81bd0f5da69084cf3c629fde68a1b" kindref="member">sensor_value.val2</ref></computeroutput> is unused (always 0). </para>

    <sectiondef kind="define">
      <memberdef kind="define" id="group__bsd__socket__service_1ga424f319f9ccc675f8eeca23cb2c91bc4" prot="public" static="no">
        <name>NET_SOCKET_SERVICE_SYNC_DEFINE</name>
        <param><defname>name</defname></param>
        <param><defname>cb</defname></param>
        <param><defname>count</defname></param>
        <initializer>	__z_net_socket_service_define(name, cb, count)</initializer>
        <briefdescription>
<para>Statically define a network socket service. </para>
        </briefdescription>
        <detaileddescription>
<para>The user callback is called synchronously for this service meaning that the service API will wait until the user callback returns before continuing with next socket service.</para>
<para>The socket service can be accessed outside the module where it is defined using:</para>
<para><programlisting><codeline><highlight class="normal">extern<sp/>struct<sp/>net_socket_service_desc<sp/>&lt;name&gt;;<sp/></highlight></codeline>
</programlisting></para>
<para><simplesect kind="note"><para>This macro cannot be used together with a static keyword. If such a use-case is desired, use NET_SOCKET_SERVICE_SYNC_DEFINE_STATIC instead.</para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>name</parametername>
</parameternamelist>
<parameterdescription>
<para>Name of the service. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>cb</parametername>
</parameternamelist>
<parameterdescription>
<para>Callback function that is called for socket activity. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>count</parametername>
</parameternamelist>
<parameterdescription>
<para>How many pollable sockets is needed for this service. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/net/socket_service.h" line="136" column="9" bodyfile="zephyr/net/socket_service.h" bodystart="136" bodyend="137"/>
      </memberdef>

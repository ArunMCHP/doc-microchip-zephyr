</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>calibration</parametername>
</parameternamelist>
<parameterdescription>
<para>Calibration to set in parts per billion</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 if successful </para>
</simplesect>
<simplesect kind="return"><para>-EINVAL if calibration is out of range </para>
</simplesect>
<simplesect kind="return"><para>-ENOTSUP if API is not supported by hardware </para>

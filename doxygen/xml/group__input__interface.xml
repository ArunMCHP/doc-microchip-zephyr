      <memberdef kind="define" id="group__input__interface_1gad3e7310625b14db2e6930f66dfd879a7" prot="public" static="no">
        <name>INPUT_CALLBACK_DEFINE_NAMED</name>
        <param><defname>_dev</defname></param>
        <param><defname>_callback</defname></param>
        <param><defname>_user_data</defname></param>
        <param><defname>name</defname></param>
        <initializer>	static const <ref refid="group__iterable__section__apis_1ga9104f42cbe4a67a931bed7f7cc8f600f" kindref="member">STRUCT_SECTION_ITERABLE</ref>(<ref refid="structinput__callback" kindref="compound">input_callback</ref>,                   \
					     _input_callback__##name) = {      \
		.dev = _dev,                                                   \
		.callback = _callback,                                         \
		.user_data = _user_data,                                       \
	}</initializer>
        <briefdescription>
<para>Register a callback structure for input events with a custom name. </para>
        </briefdescription>
        <detaileddescription>
<para>Same as <ref refid="group__input__interface_1gac986cdf392f9aa0a771c8e4e92c479a3" kindref="member">INPUT_CALLBACK_DEFINE</ref> but allows specifying a custom name for the callback structure. Useful if multiple callbacks are used for the same callback function. </para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/input/input.h" line="150" column="9" bodyfile="zephyr/input/input.h" bodystart="150" bodyend="156"/>

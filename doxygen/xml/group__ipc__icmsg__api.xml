      <memberdef kind="function" id="group__ipc__icmsg__api_1ga0d8f5626406ca660e616de131f54e29d" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int icmsg_close</definition>
        <argsstring>(const struct icmsg_config_t *conf, struct icmsg_data_t *dev_data)</argsstring>
        <name>icmsg_close</name>
        <param>
          <type>const struct <ref refid="structicmsg__config__t" kindref="compound">icmsg_config_t</ref> *</type>
          <declname>conf</declname>
        </param>
        <param>
          <type>struct <ref refid="structicmsg__data__t" kindref="compound">icmsg_data_t</ref> *</type>
          <declname>dev_data</declname>
        </param>
        <briefdescription>
<para>Close an icmsg instance. </para>
        </briefdescription>
        <detaileddescription>
<para>Closing an icmsg instance results in releasing all resources used by given instance including the shared memory regions and mbox devices.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">conf</parametername>
</parameternamelist>
<parameterdescription>
<para>Structure containing configuration parameters for the icmsg instance being closed. Its content must be the same as used for creating this instance with <ref refid="group__ipc__icmsg__api_1ga6017af391a3135c02cec7929620789e8" kindref="member">icmsg_open</ref>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="inout">dev_data</parametername>
</parameternamelist>
<parameterdescription>
<para>Structure containing run-time data used by the icmsg instance.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>on success. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>other</parametername>
</parameternamelist>
<parameterdescription>
<para>errno codes from dependent modules. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

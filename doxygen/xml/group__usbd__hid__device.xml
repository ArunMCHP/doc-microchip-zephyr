</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">period_us</parametername>
</parameternamelist>
<parameterdescription>
<para>Polling period in microseconds</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success, negative errno code on failure. </para>
</simplesect>
<parameterlist kind="retval"><parameteritem>

      <memberdef kind="function" id="group__bt__bap__unicast__server_1gab3ea6014854e6290f058c87e866c3191" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int bt_bap_unicast_server_register</definition>
        <argsstring>(const struct bt_bap_unicast_server_register_param *param)</argsstring>
        <name>bt_bap_unicast_server_register</name>
        <param>
          <type>const struct <ref refid="structbt__bap__unicast__server__register__param" kindref="compound">bt_bap_unicast_server_register_param</ref> *</type>
          <declname>param</declname>
        </param>
        <briefdescription>
<para>Register the Unicast Server. </para>
        </briefdescription>
        <detaileddescription>
<para>Register the Unicast Server. Only a single Unicast Server can be registered at any one time. This will register ASCS in the GATT database.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>param</parametername>
</parameternamelist>
<parameterdescription>
<para>Registration parameters for ascs.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 in case of success, negative error code otherwise. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/bluetooth/audio/bap.h" line="1525" column="5" declfile="zephyr/bluetooth/audio/bap.h" declline="1525" declcolumn="5"/>

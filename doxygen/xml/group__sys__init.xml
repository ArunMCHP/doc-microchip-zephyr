        <name>SYS_INIT_NAMED</name>
        <param><defname>name</defname></param>
        <param><defname>init_fn_</defname></param>
        <param><defname>level</defname></param>
        <param><defname>prio</defname></param>
        <initializer>	static const Z_DECL_ALIGN(struct <ref refid="structinit__entry" kindref="compound">init_entry</ref>)                                      \
		Z_INIT_ENTRY_SECTION(level, prio, 0) __used __noasan                      \
		Z_INIT_ENTRY_NAME(name) = {.init_fn = (init_fn_), .dev = <ref refid="iar__missing__defs_8h_1a070d2ce7b6bb7e5c05602aa8c308d0c4" kindref="member">NULL</ref>}            \</initializer>
        <briefdescription>
<para>Register an initialization function (named). </para>
        </briefdescription>
        <detaileddescription>
<para><simplesect kind="note"><para>This macro can be used for cases where the multiple init calls use the same init function.</para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>name</parametername>
</parameternamelist>
<parameterdescription>
<para>Unique name for SYS_INIT entry. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>init_fn_</parametername>
</parameternamelist>
<parameterdescription>
<para>See <ref refid="group__sys__init_1gaf507cc0613add8113c41896bd631254f" kindref="member">SYS_INIT()</ref>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>level</parametername>
</parameternamelist>
<parameterdescription>
<para>See <ref refid="group__sys__init_1gaf507cc0613add8113c41896bd631254f" kindref="member">SYS_INIT()</ref>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>prio</parametername>
</parameternamelist>
<parameterdescription>
<para>See <ref refid="group__sys__init_1gaf507cc0613add8113c41896bd631254f" kindref="member">SYS_INIT()</ref>.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="see"><para><ref refid="group__sys__init_1gaf507cc0613add8113c41896bd631254f" kindref="member">SYS_INIT()</ref> </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>

</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>pixel2</parametername>
</parameternamelist>
<parameterdescription>
<para>Second pixel (low nibble, right pixel) </para>
</parameterdescription>
</parameteritem>
</parameterlist>

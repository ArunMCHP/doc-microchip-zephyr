      <memberdef kind="define" id="kinetis__sim_8h_1a602fd24d5700e74aac914d0d15053b9e" prot="public" static="no">
        <name>KINETIS_SIM_CLOCK</name>
        <param><defname>name</defname></param>
        <param><defname>offset</defname></param>
        <param><defname>bits</defname></param>
        <initializer>	KINETIS_SIM_CLOCK_ID(name, offset, bits) offset bits</initializer>
        <briefdescription>
<para>Build a 3-cell SIM clock specifier. </para>
        </briefdescription>
        <detaileddescription>
<para>Expands to &lt;id offset bits&gt; where <computeroutput>id</computeroutput> encodes gate and rate information, and <computeroutput>offset</computeroutput>/<computeroutput>bits</computeroutput> are kept explicit for readability and for consumers (e.g. ADC16) that read them as separate cells.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>name</parametername>
</parameternamelist>
<parameterdescription>
<para>Clock name selector (KINETIS_SIM_*_CLK) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>offset</parametername>
</parameternamelist>
<parameterdescription>
<para>Gate register offset (e.g. 0x1034) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>bits</parametername>
</parameternamelist>
<parameterdescription>
<para>Gate bit index (0..31) </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

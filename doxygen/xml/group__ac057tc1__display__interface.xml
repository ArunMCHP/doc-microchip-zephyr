        <param><defname>pixel2</defname></param>
        <initializer>(((pixel1) &lt;&lt; 4) | ((pixel2) &amp; 0x0F))</initializer>
        <briefdescription>
<para>Pack two AC057TC1 pixels into a single byte. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>pixel1</parametername>
</parameternamelist>
<parameterdescription>

      <memberdef kind="function" id="group__subsys__pm__sys__policy_1gae2680fcc323e161362e4a5aa5339ac12" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type><ref refid="stdint_8h_1ac714c0d2c1a4adb10e73cab29623314b" kindref="member">int64_t</ref></type>
        <definition>int64_t pm_policy_next_event_ticks</definition>
        <argsstring>(void)</argsstring>
        <name>pm_policy_next_event_ticks</name>
        <param>
          <type>void</type>
        </param>
        <briefdescription>
<para>Returns the ticks until the next event. </para>
        </briefdescription>
        <detaileddescription>
<para>Returns a relative timeout, in uptime ticks, until the earliest (soonest) registered event.</para>
<para>The return value follows these rules:<itemizedlist>
<listitem><para>If at least one event is registered and its scheduled time is in the future, returns the number of ticks until that event.</para>
</listitem><listitem><para>If the earliest event is due now or already in the past, returns 0.</para>
</listitem><listitem><para>If no events are registered, returns -1.</para>
</listitem></itemizedlist>
</para>
<para><parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>&gt;0</parametername>
</parameternamelist>
<parameterdescription>
<para>If next registered event is in the future </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>If next registered event is now or in the past </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-1</parametername>
</parameternamelist>
<parameterdescription>
<para>Otherwise </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/pm/policy.h" line="274" column="9" declfile="zephyr/pm/policy.h" declline="274" declcolumn="9"/>
      </memberdef>

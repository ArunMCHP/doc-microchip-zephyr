          <type>struct <ref refid="structzms__fs" kindref="compound">zms_fs</ref> *</type>
          <declname>fs</declname>
        </param>
        <briefdescription>
<para>Mount a ZMS file system onto the device specified in <computeroutput>fs</computeroutput>. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>fs</parametername>
</parameternamelist>
<parameterdescription>

        <type>void</type>
        <definition>void console_set_rx_timeout</definition>
        <argsstring>(k_timeout_t timeout)</argsstring>
        <name>console_set_rx_timeout</name>
        <param>
          <type><ref refid="structk__timeout__t" kindref="compound">k_timeout_t</ref></type>
          <declname>timeout</declname>
        </param>
        <briefdescription>
<para>Set receive timeout for console operations. </para>
        </briefdescription>
        <detaileddescription>
<para>Set timeout for <ref refid="group__console__api_1ga2ba36eb1081cd0b98aa43216ccd6fbd5" kindref="member">console_getchar()</ref> and <ref refid="group__console__api_1ga27785534c14d4098822db2b870b7d81d" kindref="member">console_read()</ref> operations. Default timeout after initialization is K_FOREVER.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>timeout</parametername>
</parameternamelist>
<parameterdescription>
<para>Maximum time to wait when reading. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

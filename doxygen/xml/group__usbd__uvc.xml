  <compounddef id="group__usbd__uvc" kind="group">
    <compoundname>usbd_uvc</compoundname>
    <title>USB Video Class (UVC) device API</title>
    <sectiondef kind="func">
      <memberdef kind="function" id="group__usbd__uvc_1ga9c84595e78a2294f1470056199c074ae" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void uvc_device_init</definition>
        <argsstring>(const struct device *uvc_dev, const struct device *video_dev)</argsstring>
        <name>uvc_device_init</name>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *</type>
          <declname>uvc_dev</declname>
        </param>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *</type>
          <declname>video_dev</declname>
        </param>
        <briefdescription>
<para>Initialize a video device class. </para>
        </briefdescription>
        <detaileddescription>
<para>Set the video device that a UVC instance will use for control requests.</para>
<para>It will query its supported video controls and frame intervals and use this information to generate the USB descriptors presented to the host. In addition, for every supported UVC control request from the host to this <computeroutput>uvc_dev</computeroutput> instance, it will issue a matching video API control request to <computeroutput>video_dev</computeroutput>.</para>
<para><simplesect kind="note"><para>This function must be called before <ref refid="group__usbd__uvc_1gaec4b7ac54a524724bb29751fd1cafafe" kindref="member">uvc_device_enable</ref>.</para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>uvc_dev</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the UVC device to configure </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>video_dev</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the video device to which controls requests are sent </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/usb/class/usbd_uvc.h" line="43" column="6" declfile="zephyr/usb/class/usbd_uvc.h" declline="43" declcolumn="6"/>
      </memberdef>
      <memberdef kind="function" id="group__usbd__uvc_1gacdfc08f59e0032e68b838f5893edbda1" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int uvc_device_add_format</definition>
        <argsstring>(const struct device *const uvc_dev, const struct video_format *const fmt)</argsstring>
        <name>uvc_device_add_format</name>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *const</type>
          <declname>uvc_dev</declname>
        </param>
        <param>
          <type>const struct <ref refid="structvideo__format" kindref="compound">video_format</ref> *const</type>
          <declname>fmt</declname>
        </param>
        <briefdescription>
<para>Add a video format that a UVC instance will present to the host. </para>
        </briefdescription>
        <detaileddescription>
<para>This information will be used to generate USB descriptors. The particular format selected by the host can be queried with <ref refid="group__video__interface_1gad4a5849af21d20197169f0557329fdc1" kindref="member">video_get_format</ref>.</para>
<para><simplesect kind="note"><para>This function must be called before <ref refid="group__usbd__uvc_1gaec4b7ac54a524724bb29751fd1cafafe" kindref="member">uvc_device_enable</ref>.</para>
</simplesect>
<simplesect kind="note"><para>The <computeroutput>fmt</computeroutput> struct field <computeroutput>size</computeroutput> must be set prior to call this function, such as calling <ref refid="group__video__interface_1gab93c2cb09bf5b0629b665cc4a079e3cd" kindref="member">video_set_format()</ref>.</para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>uvc_dev</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the UVC device to configure </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>fmt</parametername>
</parameternamelist>
<parameterdescription>
<para>The video format to add to this UVC instance </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success, negative value on error </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/usb/class/usbd_uvc.h" line="60" column="5" declfile="zephyr/usb/class/usbd_uvc.h" declline="60" declcolumn="5"/>
      </memberdef>
      <memberdef kind="function" id="group__usbd__uvc_1gaec4b7ac54a524724bb29751fd1cafafe" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">

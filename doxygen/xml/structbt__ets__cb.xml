        <name>read_elapsed_time</name>
        <qualifiedname>bt_ets_cb::read_elapsed_time</qualifiedname>
        <briefdescription>
<para>Read elapsed time callback (MANDATORY). </para>
        </briefdescription>
        <detaileddescription>
<para>Called when a BLE client reads the Current Elapsed Time characteristic. Application must fill the elapsed time structure with current time information.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>time</parametername>
</parameternamelist>
<parameterdescription>
<para>Elapsed time structure to fill.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>On success. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-errno</parametername>
</parameternamelist>
<parameterdescription>
<para>Negative errno on failure. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

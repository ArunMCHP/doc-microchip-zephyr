      <memberdef kind="function" id="group__arch-irq_1gab7c91d90ed8ccfce15c8bd040496f9ac" prot="public" static="yes" const="no" explicit="no" inline="yes" virt="non-virtual">
        <type><ref refid="stdbool_8h_1abb452686968e48b67397da5f97445f5b" kindref="member">bool</ref></type>
        <definition>static bool arch_cpu_irqs_are_enabled</definition>
        <argsstring>(void)</argsstring>
        <name>arch_cpu_irqs_are_enabled</name>
        <param>
          <type>void</type>
        </param>
        <briefdescription>
<para>Probe the current CPU overall interrupt controller lock state without modifying it. </para>
        </briefdescription>
        <detaileddescription>
<para>Unlike <ref refid="group__arch-irq_1ga1b827afafc622d412962f568b78726dc" kindref="member">arch_irq_unlocked()</ref> which inspects a saved key, this reports the instantaneous state of the calling CPU&apos;s overall interrupt enable.</para>
<para><simplesect kind="return"><para>true if interrupts are currently enabled on the calling CPU. </para>
</simplesect>
</para>
        </detaileddescription>

        <param><defname>inst</defname></param>
        <param><defname>delay_</defname></param>
        <initializer><ref refid="group__mspi__devicetree_1ga501b2e19e358083f2b47838cde58a676" kindref="member">MSPI_CE_CONTROL_INIT</ref>(<ref refid="group__devicetree-inst_1ga219f413efba2f4c0151468b9a25a8dc1" kindref="member">DT_DRV_INST</ref>(inst), delay_)</initializer>

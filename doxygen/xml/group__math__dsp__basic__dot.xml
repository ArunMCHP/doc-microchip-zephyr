        <definition>DSP_FUNC_SCOPE void zdsp_dot_prod_q31</definition>
        <argsstring>(const DSP_DATA q31_t *src_a, const DSP_DATA q31_t *src_b, uint32_t block_size, DSP_DATA q63_t *result)</argsstring>
        <name>zdsp_dot_prod_q31</name>
        <param>
          <type>const <ref refid="dsp_8h_1a2ba5cab25d6c097e55bbe14094a06c7c" kindref="member">DSP_DATA</ref> <ref refid="group__math__dsp_1gad8c011580ce38d45dc58d831ab145258" kindref="member">q31_t</ref> *</type>

		    Z_INIT_PRE_KERNEL_2_##level, (Z_INIT_ORD_PRE_KERNEL_2),    \
		    Z_INIT_POST_KERNEL_##level, (Z_INIT_ORD_POST_KERNEL),      \
		    Z_INIT_APPLICATION_##level, (Z_INIT_ORD_APPLICATION),      \
		    Z_INIT_SMP_##level, (Z_INIT_ORD_SMP),                      \

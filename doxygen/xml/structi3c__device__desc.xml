      <memberdef kind="variable" id="structi3c__device__desc_1a4e4c9614871e5ea4aa08b1560ecc40d0" prot="public" static="no" mutable="no">
        <type><ref refid="stdint_8h_1a3cb4a16b0e8d6af0af86d4fd6ba5fd9d" kindref="member">uint8_t</ref></type>
        <definition>uint8_t i3c_device_desc::dynamic_addr</definition>
        <argsstring></argsstring>
        <name>dynamic_addr</name>
        <qualifiedname>i3c_device_desc::dynamic_addr</qualifiedname>
        <briefdescription>
<para>Dynamic Address for this target device used for communication. </para>
        </briefdescription>
        <detaileddescription>
<para>This is to be set by the controller driver in one of the following situations:<itemizedlist>
<listitem><para>During Dynamic Address Assignment (during ENTDAA)</para>
</listitem><listitem><para>Reset Dynamic Address Assignment (RSTDAA)</para>
</listitem><listitem><para>Set All Addresses to Static Addresses (SETAASA)</para>
</listitem><listitem><para>Set New Dynamic Address (SETNEWDA)</para>
</listitem><listitem><para>Set Dynamic Address from Static Address (SETDASA)</para>
</listitem></itemizedlist>
</para>
<para>0 if address has not been assigned. </para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/drivers/i3c.h" line="983" column="9" bodyfile="zephyr/drivers/i3c.h" bodystart="983" bodyend="-1"/>

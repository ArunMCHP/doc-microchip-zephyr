      <memberdef kind="define" id="devicetree__regions_8h_1a9df6c66f56e571a0dada9ab46b40ba26" prot="public" static="no">
        <name>LINKER_DT_NODE_REGION_NAME_TOKEN</name>
        <param><defname>node_id</defname></param>
        <initializer>	<ref refid="group__devicetree-generic-prop_1ga5995350cc7fd2d12ef7daa2487d1db54" kindref="member">DT_STRING_TOKEN</ref>(node_id, zephyr_memory_region)</initializer>
        <briefdescription>
<para>Get the linker memory-region name in a token form. </para>
        </briefdescription>
        <detaileddescription>
<para>This attempts to use the zephyr,memory-region property (with non-alphanumeric characters replaced with underscores) returning a token.</para>
<para>Example devicetree fragment:</para>
<para><programlisting filename=".dts"><codeline><highlight class="normal">/<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>soc<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>sram1:<sp/>memory@2000000<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>zephyr,memory-region<sp/>=<sp/>&quot;MY_NAME&quot;;</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>};</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>sram2:<sp/>memory@2001000<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>zephyr,memory-region<sp/>=<sp/>&quot;MY@OTHER@NAME&quot;;</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>};</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>};</highlight></codeline>
<codeline><highlight class="normal">};</highlight></codeline>
</programlisting></para>
<para>Example usage:</para>
<para><programlisting filename=".c"><codeline><highlight class="normal"><ref refid="devicetree__regions_8h_1a9df6c66f56e571a0dada9ab46b40ba26" kindref="member">LINKER_DT_NODE_REGION_NAME_TOKEN</ref>(<ref refid="group__devicetree-generic-id_1gab7d23294a6bf7fd44a98b48ec47d8a79" kindref="member">DT_NODELABEL</ref>(sram1))<sp/></highlight><highlight class="comment">//<sp/>MY_NAME</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="devicetree__regions_8h_1a9df6c66f56e571a0dada9ab46b40ba26" kindref="member">LINKER_DT_NODE_REGION_NAME_TOKEN</ref>(<ref refid="group__devicetree-generic-id_1gab7d23294a6bf7fd44a98b48ec47d8a79" kindref="member">DT_NODELABEL</ref>(sram2))<sp/></highlight><highlight class="comment">//<sp/>MY_OTHER_NAME</highlight></codeline>
</programlisting></para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>node_id</parametername>
</parameternamelist>

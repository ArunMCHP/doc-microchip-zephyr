      <memberdef kind="function" id="group__pipe__apis_1gaaedff72169127b8227c80bf8adf1f9dd" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void k_pipe_reset</definition>
        <argsstring>(struct k_pipe *pipe)</argsstring>
        <name>k_pipe_reset</name>
        <param>
          <type>struct <ref refid="structk__pipe" kindref="compound">k_pipe</ref> *</type>
          <declname>pipe</declname>
        </param>
        <briefdescription>
<para>Reset a pipe This routine resets the pipe, discarding any unread data and unblocking any threads waiting to write or read, causing the waiting threads to return with -ECANCELED. </para>
        </briefdescription>
        <detaileddescription>
<para>Calling k_pipe_read(..) or k_pipe_write(..) when the pipe is resetting but not yet reset will return -ECANCELED. The pipe is left open after a reset and can be used as normal.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>pipe</parametername>
</parameternamelist>
<parameterdescription>
<para>Address of the pipe. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/kernel.h" line="5780" column="7" declfile="zephyr/kernel.h" declline="5780" declcolumn="7"/>
      </memberdef>
      <memberdef kind="function" id="group__pipe__apis_1ga83d4b5de8902845850d01b0c3db0702a" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void k_pipe_close</definition>
        <argsstring>(struct k_pipe *pipe)</argsstring>
        <name>k_pipe_close</name>
        <param>
          <type>struct <ref refid="structk__pipe" kindref="compound">k_pipe</ref> *</type>
          <declname>pipe</declname>
        </param>
        <briefdescription>
<para>Close a pipe. </para>
        </briefdescription>
        <detaileddescription>
<para>This routine closes a pipe. Any threads that were blocked on the pipe will be unblocked and receive an error code.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>pipe</parametername>
</parameternamelist>
<parameterdescription>
<para>Address of the pipe. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/kernel.h" line="5790" column="7" declfile="zephyr/kernel.h" declline="5790" declcolumn="7"/>
      </memberdef>

      <memberdef kind="define" id="group__devicetree-interrupts-prop_1gabee933352a948bd824beccc00c13387d" prot="public" static="no">
        <name>DT_IRQ_INTC_BY_NAME</name>
        <param><defname>node_id</defname></param>
        <param><defname>name</defname></param>
        <initializer>	DT_CAT4(node_id, _IRQ_NAME_, name, _CONTROLLER)</initializer>
        <briefdescription>
<para>Get an interrupt specifier&apos;s interrupt controller by name. </para>
        </briefdescription>
        <detaileddescription>
<para><programlisting filename=".dts"><codeline><highlight class="normal">gpio0:<sp/>gpio0<sp/>{</highlight></codeline>

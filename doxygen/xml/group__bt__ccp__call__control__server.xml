<parametername>-EINVAL</parametername>
</parameternamelist>
<parameterdescription>
<para><computeroutput>bearer</computeroutput> or <computeroutput>uci</computeroutput> is NULL </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EFAULT</parametername>
</parameternamelist>
<parameterdescription>
<para><computeroutput>bearer</computeroutput> is not registered </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>

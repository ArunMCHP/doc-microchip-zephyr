      <memberdef kind="function" id="group__low__level__heap__allocator_1ga81de9cc56f9fb88ae12ea70cc85d1db1" prot="public" static="yes" const="no" explicit="no" inline="yes" virt="non-virtual">
        <type><ref refid="stdbool_8h_1abb452686968e48b67397da5f97445f5b" kindref="member">bool</ref></type>
        <definition>static bool sys_heap_validate</definition>
        <argsstring>(struct sys_heap *heap)</argsstring>
        <name>sys_heap_validate</name>
        <param>
          <type>struct <ref refid="structsys__heap" kindref="compound">sys_heap</ref> *</type>
          <declname>heap</declname>
        </param>
        <briefdescription>
<para>Validate heap integrity. </para>
        </briefdescription>
        <detaileddescription>
<para>Validates the internal integrity of a <ref refid="structsys__heap" kindref="compound">sys_heap</ref>. Intended for unit test and validation code, though potentially useful as a user API for applications with complicated runtime reliability requirements. Note: this cannot catch every possible error, but if it returns true then the heap is in a consistent state and can correctly handle any <ref refid="group__low__level__heap__allocator_1ga6b8bdf02c9be5576fddbe711904a3aad" kindref="member">sys_heap_alloc()</ref> request and free any live pointer returned from a previous allocation.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>heap</parametername>
</parameternamelist>
<parameterdescription>
<para>Heap to validate </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>true, if the heap is valid, otherwise false </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

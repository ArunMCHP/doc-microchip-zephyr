        <name>CAN_DT_DRIVER_CONFIG_GET</name>
        <param><defname>node_id</defname></param>
        <param><defname>_min_bitrate</defname></param>
        <param><defname>_max_bitrate</defname></param>
        <initializer>	{											\
		.phy = <ref refid="group__device__model_1ga6ce1dbfda6847ca6c3858712e9b41989" kindref="member">DEVICE_DT_GET_OR_NULL</ref>(<ref refid="group__devicetree-generic-prop_1ga7bd77c49472ba4547d87f00f40fd7171" kindref="member">DT_PHANDLE</ref>(node_id, phys)),			\
		.min_bitrate = <ref refid="group__devicetree-can_1ga60cb3dc5c2feb517dddcb5a57cce8a9b" kindref="member">DT_CAN_TRANSCEIVER_MIN_BITRATE</ref>(node_id, _min_bitrate),		\
		.max_bitrate = <ref refid="group__devicetree-can_1ga9c56ded2142fbd8a4a7facffd3dd549d" kindref="member">DT_CAN_TRANSCEIVER_MAX_BITRATE</ref>(node_id, _max_bitrate),		\
		.bitrate = <ref refid="group__devicetree-generic-prop_1ga5e5bfc9b1a6627b3f73014329e96340f" kindref="member">DT_PROP_OR</ref>(node_id, bitrate,						\
			<ref refid="group__devicetree-generic-prop_1ga5e5bfc9b1a6627b3f73014329e96340f" kindref="member">DT_PROP_OR</ref>(node_id, bus_speed, CONFIG_CAN_DEFAULT_BITRATE)),            \
		.sample_point = <ref refid="group__devicetree-generic-prop_1ga5e5bfc9b1a6627b3f73014329e96340f" kindref="member">DT_PROP_OR</ref>(node_id, sample_point, 0),				\
		<ref refid="group__sys-util_1gae67ffe50e848951dbde309ed569ea925" kindref="member">IF_ENABLED</ref>(CONFIG_CAN_FD_MODE,							\
			(.bitrate_data = <ref refid="group__devicetree-generic-prop_1ga5e5bfc9b1a6627b3f73014329e96340f" kindref="member">DT_PROP_OR</ref>(node_id, bitrate_data,                      \
			 <ref refid="group__devicetree-generic-prop_1ga5e5bfc9b1a6627b3f73014329e96340f" kindref="member">DT_PROP_OR</ref>(node_id, bus_speed_data, CONFIG_CAN_DEFAULT_BITRATE_DATA)), \
			 .sample_point_data = <ref refid="group__devicetree-generic-prop_1ga5e5bfc9b1a6627b3f73014329e96340f" kindref="member">DT_PROP_OR</ref>(node_id, sample_point_data, 0),))	\
	}</initializer>

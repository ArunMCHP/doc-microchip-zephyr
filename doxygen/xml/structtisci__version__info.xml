    <briefdescription>
<para>version information structure </para>
    </briefdescription>
    <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>abi_major</parametername>
</parameternamelist>
<parameterdescription>
<para>Major ABI version. Change here implies risk of backward compatibility break. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>abi_minor</parametername>
</parameternamelist>
<parameterdescription>
<para>Minor ABI version. Change here implies new feature addition, or compatible change in ABI. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>firmware_revision</parametername>
</parameternamelist>
<parameterdescription>
<para>Firmware revision (not usually used). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>firmware_description</parametername>
</parameternamelist>
<parameterdescription>
<para>Firmware description (not usually used). </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>

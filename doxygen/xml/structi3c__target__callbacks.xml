        <type>int(*</type>
        <definition>int(* i3c_target_callbacks::controller_handoff_cb) (struct i3c_target_config *config)</definition>
        <argsstring>)(struct i3c_target_config *config)</argsstring>
        <name>controller_handoff_cb</name>
        <qualifiedname>i3c_target_callbacks::controller_handoff_cb</qualifiedname>
        <briefdescription>
<para>Function called when an active controller handoffs controlership to this target. </para>
        </briefdescription>
        <detaileddescription>
<para>This function is invoked by the active controller when it handoffs controllership to this target. This can happen wither the target has requested it or if the active controller chooses to handoff to the controller capable target.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>config</parametername>
</parameternamelist>
<parameterdescription>
<para>Configuration structure associated with the device to which the operation is addressed.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>Ignored. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/drivers/i3c/target_device.h" line="279" column="1" bodyfile="zephyr/drivers/i3c/target_device.h" bodystart="279" bodyend="-1"/>

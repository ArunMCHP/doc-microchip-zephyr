      <memberdef kind="function" id="group__timing__api__arch_1gaf8cd88e81c2104b5eb0fbe42967b7834" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void arch_timing_start</definition>
        <argsstring>(void)</argsstring>
        <name>arch_timing_start</name>
        <param>
          <type>void</type>
        </param>
        <briefdescription>
<para>Signal the start of the timing information gathering. </para>
        </briefdescription>
        <detaileddescription>
<para>Signal to the timing subsystem that timing information will be gathered from this point forward.</para>
<para><simplesect kind="note"><para>Any call to <ref refid="group__timing__api__arch_1gad7a709477650c8596a96fe080f583fdd" kindref="member">arch_timing_counter_get()</ref> must be done between calls to <ref refid="group__timing__api__arch_1gaf8cd88e81c2104b5eb0fbe42967b7834" kindref="member">arch_timing_start()</ref> and <ref refid="group__timing__api__arch_1ga566483c64f5c5d2f0465e3f969303fd3" kindref="member">arch_timing_stop()</ref>, and on the same CPU core.</para>
</simplesect>
<simplesect kind="see"><para><ref refid="group__timing__api_1ga3c28bb4ced0467c284d33c800e070bde" kindref="member">timing_start()</ref> </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

  <compounddef id="group__bt__goep__transport__rfcomm" kind="group">
    <compoundname>bt_goep_transport_rfcomm</compoundname>
    <title>GOEP transport RFCOMM</title>
    <innerclass refid="structbt__goep__transport__rfcomm__server" prot="public">bt_goep_transport_rfcomm_server</innerclass>
    <sectiondef kind="func">
      <memberdef kind="function" id="group__bt__goep__transport__rfcomm_1ga781dc33ffa086753319c84f59b8e977f" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int bt_goep_transport_rfcomm_server_register</definition>
        <argsstring>(struct bt_goep_transport_rfcomm_server *server)</argsstring>
        <name>bt_goep_transport_rfcomm_server_register</name>
        <param>
          <type>struct <ref refid="structbt__goep__transport__rfcomm__server" kindref="compound">bt_goep_transport_rfcomm_server</ref> *</type>
          <declname>server</declname>
        </param>
        <briefdescription>
<para>Register GOEP RFCOMM server. </para>
        </briefdescription>
        <detaileddescription>
<para>Register GOEP server for a RFCOMM channel <ref refid="structbt__rfcomm__server_1a30b22ea64c0fdd7130e8aaa79519e776" kindref="member">bt_rfcomm_server::channel</ref>, each new connection is authorized using the <ref refid="structbt__goep__transport__rfcomm__server_1a66c433a47c20018f9f0a018b4fbc8048" kindref="member">bt_goep_transport_rfcomm_server::accept</ref> callback which in case of success shall allocate the GOEP structure <ref refid="group__bt__goep" kindref="compound">Generic Object Exchange Profile (GOEP)</ref> to be used by the new GOEP connection.</para>
<para><ref refid="structbt__rfcomm__server_1a30b22ea64c0fdd7130e8aaa79519e776" kindref="member">bt_rfcomm_server::channel</ref> may be pre-set to a given value (not recommended however). Or be left as 0, in which case the channel will be auto-allocated by RFCOMM.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>server</parametername>
</parameternamelist>
<parameterdescription>
<para>Server structure.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 in case of success or negative value in case of error. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/bluetooth/classic/goep.h" line="182" column="5" declfile="zephyr/bluetooth/classic/goep.h" declline="182" declcolumn="5"/>

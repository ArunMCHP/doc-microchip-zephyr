<parameternamelist>
<parametername>path</parametername>
</parameternamelist>
<parameterdescription>
<para>LwM2M path of the cached resource. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>element</parametername>
</parameternamelist>
<parameterdescription>
<para>Candidate sample about to be cached.</para>
</parameterdescription>
</parameteritem>
</parameterlist>

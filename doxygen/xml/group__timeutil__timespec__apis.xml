      <memberdef kind="function" id="group__timeutil__timespec__apis_1ga2426889e703021e8b6f8a0ccab885bb6" prot="public" static="yes" const="no" explicit="no" inline="yes" virt="non-virtual">
        <type><ref refid="stdbool_8h_1abb452686968e48b67397da5f97445f5b" kindref="member">bool</ref></type>
        <definition>static bool timespec_is_valid</definition>
        <argsstring>(const struct timespec *ts)</argsstring>
        <name>timespec_is_valid</name>
        <param>
          <type>const struct <ref refid="structtimespec" kindref="compound">timespec</ref> *</type>
          <declname>ts</declname>
        </param>
        <briefdescription>
<para>Check if a timespec is valid. </para>
        </briefdescription>
        <detaileddescription>
<para>Check if a timespec is valid (i.e. normalized) by ensuring that the <computeroutput>tv_nsec</computeroutput> field is in the range <computeroutput>[0, NSEC_PER_SEC-1]</computeroutput>.</para>
<para><simplesect kind="note"><para><computeroutput>ts</computeroutput> must not be <computeroutput>NULL</computeroutput>.</para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>ts</parametername>
</parameternamelist>
<parameterdescription>
<para>the timespec to check</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><computeroutput>true</computeroutput> if the timespec is valid, otherwise <computeroutput>false</computeroutput>. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/sys/timeutil.h" line="379" column="20" bodyfile="zephyr/sys/timeutil.h" bodystart="379" bodyend="384"/>

      <memberdef kind="function" id="group__bt__l2cap__br_1gad1b4d59a8849124518bb973233b3f362" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int bt_l2cap_br_connless_register</definition>
        <argsstring>(struct bt_l2cap_br_connless_cb *cb)</argsstring>
        <name>bt_l2cap_br_connless_register</name>
        <param>
          <type>struct <ref refid="structbt__l2cap__br__connless__cb" kindref="compound">bt_l2cap_br_connless_cb</ref> *</type>
          <declname>cb</declname>
        </param>
        <briefdescription>
<para>Register connectionless data channel callbacks. </para>
        </briefdescription>
        <detaileddescription>
<para>Register callbacks to monitor and receive connectionless data channel frames. This allows the application to receive data sent to a specific PSM without establishing a connection.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>cb</parametername>
</parameternamelist>
<parameterdescription>
<para>Callback struct. Must point to memory that remains valid. The PSM field must be set to the desired Protocol/Service Multiplexer value, or 0 to receive all connectionless data frames.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>Success. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EINVAL</parametername>
</parameternamelist>
<parameterdescription>
<para>If <computeroutput>cb</computeroutput> is NULL, has invalid PSM value, has invalid <computeroutput>recv</computeroutput> callback, or has invalid security level. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EEXIST</parametername>
</parameternamelist>
<parameterdescription>
<para>If a callback with the same PSM was already registered. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

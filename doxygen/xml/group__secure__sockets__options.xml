      <memberdef kind="define" id="group__secure__sockets__options_1gac02711515e3bdfabe41061cfc65f5c67" prot="public" static="no">
        <name>ZSOCK_TLS_PEER_VERIFY</name>
        <initializer>5</initializer>
        <briefdescription>
<para>Write-only socket option to set peer verification level for TLS connection. </para>
        </briefdescription>
        <detaileddescription>
<para>This option accepts an integer with a peer verification level, compatible with mbedTLS values:<itemizedlist>
<listitem><para>0 - none</para>
</listitem><listitem><para>1 - optional</para>
</listitem><listitem><para>2 - required</para>
</listitem></itemizedlist>
</para>
<para>If not set, socket will use mbedTLS defaults (none for servers, required for clients). </para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/net/socket.h" line="146" column="9" bodyfile="zephyr/net/socket.h" bodystart="146" bodyend="-1"/>
      </memberdef>
      <memberdef kind="define" id="group__secure__sockets__options_1ga7f7a51d68a1901948696d597f0548488" prot="public" static="no">
        <name>ZSOCK_TLS_DTLS_ROLE</name>
        <initializer>6</initializer>
        <briefdescription>
<para>Write-only socket option to set role for DTLS connection. </para>
        </briefdescription>
        <detaileddescription>
<para>This option is irrelevant for TLS connections, as for them role is selected based on <ref refid="posix_2sys_2socket_8h_1a90f0aa598d0f4ab4ea99ecf289a6a7fb" kindref="member">connect()</ref>/listen() usage. By default, DTLS will assume client role. This option accepts an integer with a TLS role, compatible with mbedTLS values:<itemizedlist>
<listitem><para>0 - client</para>
</listitem><listitem><para>1 - server </para>
</listitem></itemizedlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/net/socket.h" line="155" column="9" bodyfile="zephyr/net/socket.h" bodystart="155" bodyend="-1"/>
      </memberdef>

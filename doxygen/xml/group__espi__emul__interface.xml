<parameteritem>
<parameternamelist>
<parametername>vw</parametername>
</parameternamelist>
<parameterdescription>
<para>The signal to be set. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>level</parametername>
</parameternamelist>
<parameterdescription>
<para>The level of signal requested LOW(0) or HIGH(1).</para>
</parameterdescription>

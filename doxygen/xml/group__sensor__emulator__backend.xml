          <declname>lower</declname>
        </param>
        <param>
          <type><ref refid="group__math__dsp_1gad8c011580ce38d45dc58d831ab145258" kindref="member">q31_t</ref> *</type>
          <declname>upper</declname>
        </param>
        <param>
          <type><ref refid="group__math__dsp_1gad8c011580ce38d45dc58d831ab145258" kindref="member">q31_t</ref> *</type>
          <declname>epsilon</declname>
        </param>
        <param>
          <type><ref refid="stdint_8h_1accbd6432732c88ad6adc5365800433b6" kindref="member">int8_t</ref> *</type>
          <declname>shift</declname>
        </param>
        <briefdescription>
<para>Query an emulator for a channel&apos;s supported sample value range and tolerance. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>target</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to emulator instance to operate on </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>ch</parametername>
</parameternamelist>
<parameterdescription>
<para>The channel to request info for. If <computeroutput>ch</computeroutput> is unsupported, return <computeroutput>-ENOTSUP</computeroutput> </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">lower</parametername>
</parameternamelist>
<parameterdescription>
<para>Minimum supported sample value in SI units, fixed-point format </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">upper</parametername>
</parameternamelist>
<parameterdescription>
<para>Maximum supported sample value in SI units, fixed-point format </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">epsilon</parametername>
</parameternamelist>
<parameterdescription>
<para>Tolerance to use comparing expected and actual values to account for rounding and sensor precision issues. This can usually be set to the minimum sample value step size. Uses SI units and fixed-point format. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">shift</parametername>
</parameternamelist>
<parameterdescription>
<para>The shift value (scaling factor) associated with <computeroutput>lower</computeroutput>, <computeroutput>upper</computeroutput>, and <computeroutput>epsilon</computeroutput>.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 if successful </para>
</simplesect>
<simplesect kind="return"><para>-ENOTSUP if no backend API or if channel not supported by emul </para>
</simplesect>
</para>
        </detaileddescription>

        <type>int</type>
        <definition>int rtc_alarm_is_pending</definition>
        <argsstring>(const struct device *dev, uint16_t id)</argsstring>
        <name>rtc_alarm_is_pending</name>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *</type>
          <declname>dev</declname>
        </param>
        <param>
          <type><ref refid="stdint_8h_1a5debae8b2a1ec20a6694c0c443ee399e" kindref="member">uint16_t</ref></type>
          <declname>id</declname>
        </param>
        <briefdescription>
<para>API for testing if RTC alarm is pending. </para>
        </briefdescription>
        <detaileddescription>
<para>Test whether or not the alarm with id is pending. If the alarm is pending, the pending status is cleared.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>dev</parametername>
</parameternamelist>
<parameterdescription>
<para>Device instance </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>id</parametername>
</parameternamelist>
<parameterdescription>
<para>Id of the alarm to test</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>1 if alarm was pending </para>
</simplesect>
<simplesect kind="return"><para>0 if alarm was not pending </para>
</simplesect>
<simplesect kind="return"><para>-EINVAL if id is out of range </para>
</simplesect>
<simplesect kind="return"><para>-ENOTSUP if API is not supported by hardware </para>
</simplesect>
<simplesect kind="return"><para>-errno code if failure </para>
</simplesect>
</para>
        </detaileddescription>

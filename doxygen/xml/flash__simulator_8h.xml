</parameternamelist>
<parameterdescription>
<para>size of the ram buffer.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>pointer</parametername>
</parameternamelist>
<parameterdescription>
<para>to the ram buffer </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>

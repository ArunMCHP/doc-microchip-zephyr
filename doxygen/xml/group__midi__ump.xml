      <memberdef kind="define" id="group__midi__ump_1gac718c321652066f1537ead1524137949" prot="public" static="no">
        <name>UMP_NUM_WORDS_LOOKUP_TABLE</name>
        <initializer>	((0U &lt;&lt; 0) | (0U &lt;&lt; 2) | (0U &lt;&lt; 4) | (1U &lt;&lt; 6) | \
	(1U &lt;&lt; 8) | (3U &lt;&lt; 10) | (0U &lt;&lt; 12) | (0U &lt;&lt; 14) | \
	(1U &lt;&lt; 16) | (1U &lt;&lt; 18) | (1U &lt;&lt; 20) | (2U &lt;&lt; 22) | \
	(2U &lt;&lt; 24) | (3U &lt;&lt; 26) | (3U &lt;&lt; 28) | (3U &lt;&lt; 30))</initializer>
        <briefdescription>
<para>There are 16 UMP message types, each of which can be 1 to 4 uint32 long. </para>
        </briefdescription>
        <detaileddescription>
<para>Hence this packed representation of 16x2b array as an uint32 lookup table </para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/audio/midi.h" line="85" column="9" bodyfile="zephyr/audio/midi.h" bodystart="85" bodyend="89"/>
      </memberdef>
      <memberdef kind="define" id="group__midi__ump_1ga31e6cb035180b3afca9980307a07c038" prot="public" static="no">
        <name>UMP_NUM_WORDS</name>
        <param><defname>ump</defname></param>
        <initializer>	(1 + ((<ref refid="group__midi__ump_1gac718c321652066f1537ead1524137949" kindref="member">UMP_NUM_WORDS_LOOKUP_TABLE</ref> &gt;&gt; (2 * <ref refid="group__midi__ump_1gafab438886f69fb74a6e058f9343867aa" kindref="member">UMP_MT</ref>(ump))) &amp; 3))</initializer>
        <briefdescription>
<para>Size of a Universal MIDI Packet, in 32bit words. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">ump</parametername>
</parameternamelist>
<parameterdescription>
<para>Universal MIDI Packet </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="see"><para><ref refid="group__ump112" kindref="compound">Universal MIDI Packet (UMP) Format and MIDI 2.0 Protocol</ref>: 2.1.4 Message Type (MT) Allocation </para>

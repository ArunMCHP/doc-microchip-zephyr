	 ((((msb) - (lsb)) &amp; <ref refid="stm32__common__clocks_8h_1aa586fb78a31845770ba45ca5b6c2eadf" kindref="member">STM32_DT_CLKSEL_WIDTH_MASK</ref>) &lt;&lt; <ref refid="stm32__common__clocks_8h_1af76fb9c45071f3d99cd700ec28e9f41b" kindref="member">STM32_DT_CLKSEL_WIDTH_SHIFT</ref>) |	\

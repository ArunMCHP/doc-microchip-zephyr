      <memberdef kind="typedef" id="group__mcumgr__transport__smp_1ga97d4083706143b50d8830b37c41de7da" prot="public" static="no">
        <type>int(*</type>
        <definition>smp_transport_out_fn</definition>
        <argsstring>)(struct net_buf *nb)</argsstring>
        <name>smp_transport_out_fn</name>
        <briefdescription>
<para>SMP transmit callback for transport. </para>
        </briefdescription>
        <detaileddescription>
<para>The supplied <ref refid="structnet__buf" kindref="compound">net_buf</ref> is always consumed, regardless of return code.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>nb</parametername>
</parameternamelist>
<parameterdescription>
<para>The <ref refid="structnet__buf" kindref="compound">net_buf</ref> to transmit.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success, <ref refid="group__mcumgr__mgmt__api_1gac5d8757a7ca945c77f405764b85ad5c5" kindref="member">mcumgr_err_t</ref> code on failure. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

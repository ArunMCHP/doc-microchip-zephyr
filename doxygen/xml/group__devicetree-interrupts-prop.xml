        <initializer>	<ref refid="group__sys-util_1ga111fe4e9d63758262fc6810a782cb32a" kindref="member">IS_ENABLED</ref>(DT_CAT4(node_id, _IRQ_NAME_, name, _VAL_irq_EXISTS))</initializer>

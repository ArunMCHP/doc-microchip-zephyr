      <memberdef kind="define" id="group__can__controller__backend_1ga0186885b4aaea6b77ae115b2faddabbb" prot="public" static="no">
        <name>CAN_CALC_TDCO</name>
        <param><defname>_timing_data</defname></param>
        <param><defname>_tdco_min</defname></param>
        <param><defname>_tdco_max</defname></param>
        <initializer>	<ref refid="group__sys-util_1gad6e7d4f6ba5a77f9ee3c04026f1c2b67" kindref="member">CLAMP</ref>((1U + _timing_data-&gt;prop_seg + _timing_data-&gt;phase_seg1) * _timing_data-&gt;prescaler,  \
	      _tdco_min, _tdco_max)</initializer>
        <briefdescription>
<para>Calculate Transmitter Delay Compensation Offset from data phase timing parameters. </para>
        </briefdescription>
        <detaileddescription>
<para>Calculates the TDC Offset in minimum time quanta (mtq) using the sample point and CAN core clock prescaler specified by a set of data phase timing parameters.</para>
<para>The result is clamped to the minimum/maximum supported TDC Offset values provided.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>_timing_data</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to data phase timing parameters. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>_tdco_min</parametername>
</parameternamelist>
<parameterdescription>
<para>Minimum supported TDC Offset value in mtq. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>_tdco_max</parametername>
</parameternamelist>
<parameterdescription>
<para>Maximum supported TDC Offset value in mtq. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>Calculated TDC Offset value in mtq. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/drivers/can.h" line="332" column="9" bodyfile="zephyr/drivers/can.h" bodystart="332" bodyend="334"/>
      </memberdef>

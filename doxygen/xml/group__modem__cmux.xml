      <memberdef kind="function" id="group__modem__cmux_1ga482171f67db206780d0b8a2cf5b32a93" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int modem_cmux_disconnect</definition>
        <argsstring>(struct modem_cmux *cmux)</argsstring>
        <name>modem_cmux_disconnect</name>
        <param>
          <type>struct modem_cmux *</type>
          <declname>cmux</declname>
        </param>
        <briefdescription>
<para>Close down and disconnect CMUX instance. </para>
        </briefdescription>
        <detaileddescription>
<para>This will close all open DLCI channels, and close down the CMUX connection.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>cmux</parametername>
</parameternamelist>
<parameterdescription>
<para>CMUX instance</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="note"><para>The bus pipe must be released using <ref refid="group__modem__cmux_1gadc7c6ff92b7ac52717151bd6bf1efdff" kindref="member">modem_cmux_release()</ref> after disconnecting before being reused. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/modem/cmux.h" line="297" column="5" declfile="zephyr/modem/cmux.h" declline="297" declcolumn="5"/>

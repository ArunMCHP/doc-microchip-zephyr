        <name>uvc_device_enable</name>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *const</type>
          <declname>uvc_dev</declname>
        </param>
        <briefdescription>
<para>Completes the configuration of an UVC device instance. </para>
        </briefdescription>
        <detaileddescription>
<para>Prepare an UVC interface for being used.</para>
<para><simplesect kind="note"><para>This function must be called before <ref refid="group__usbd__api_1ga78e5f07af641f9610cc32255efe1680f" kindref="member">usbd_init</ref>.</para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>uvc_dev</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the UVC device to configure </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success, negative value on error </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

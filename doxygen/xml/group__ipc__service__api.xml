</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>other</parametername>
</parameternamelist>
<parameterdescription>
<para>errno codes depending on the implementation of the backend. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>

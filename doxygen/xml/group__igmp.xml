          <declname>addr</declname>
        </param>
        <briefdescription>
<para>Leave a given multicast group. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>iface</parametername>
</parameternamelist>
<parameterdescription>
<para>Network interface where leave message is sent </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>addr</parametername>
</parameternamelist>
<parameterdescription>
<para>Multicast group to leave</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>Return 0 if leaving is done, &lt;0 otherwise. </para>
</simplesect>
</para>
        </detaileddescription>

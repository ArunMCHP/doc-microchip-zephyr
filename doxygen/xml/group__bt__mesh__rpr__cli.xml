      <memberdef kind="function" id="group__bt__mesh__rpr__cli_1ga934104e6ee33ba8c228fde4c68e752e1" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int bt_mesh_rpr_scan_start_ext</definition>
        <argsstring>(struct bt_mesh_rpr_cli *cli, const struct bt_mesh_rpr_node *srv, const uint8_t uuid[16], uint8_t timeout, const uint8_t *ad_types, size_t ad_count)</argsstring>

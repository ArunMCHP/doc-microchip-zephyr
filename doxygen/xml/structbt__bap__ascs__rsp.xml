        <type>enum <ref refid="group__bt__bap_1ga9ca1630544a336b15af8a8e8934c5a45" kindref="member">bt_bap_ascs_reason</ref></type>
        <definition>enum bt_bap_ascs_reason bt_bap_ascs_rsp::reason</definition>
        <argsstring></argsstring>
        <name>reason</name>
        <qualifiedname>bt_bap_ascs_rsp::reason</qualifiedname>
        <briefdescription>
<para>Response reason. </para>
        </briefdescription>
        <detaileddescription>
<para>If the Response Code is one of the following:<itemizedlist>
<listitem><para><ref refid="group__bt__bap_1gga9f7efa749c75edd32dc50503397ab9d1a5a0230629bffc7659ec8127169a90b62" kindref="member">BT_BAP_ASCS_RSP_CODE_CONF_UNSUPPORTED</ref></para>
</listitem><listitem><para><ref refid="group__bt__bap_1gga9f7efa749c75edd32dc50503397ab9d1af587ec0a8b72fd9a7379aa173a8beb21" kindref="member">BT_BAP_ASCS_RSP_CODE_CONF_REJECTED</ref> all values from <ref refid="group__bt__bap_1ga9ca1630544a336b15af8a8e8934c5a45" kindref="member">bt_bap_ascs_reason</ref> can be used.</para>
</listitem></itemizedlist>
</para>
<para>If the Response Code is one of the following:<itemizedlist>
<listitem><para><ref refid="group__bt__bap_1gga9f7efa749c75edd32dc50503397ab9d1ae6e8ebcfc2578eefec11cb9e8222eafd" kindref="member">BT_BAP_ASCS_RSP_CODE_SUCCESS</ref></para>
</listitem><listitem><para><ref refid="group__bt__bap_1gga9f7efa749c75edd32dc50503397ab9d1a96278dcde41d37b6e9fd2a926c9ff16a" kindref="member">BT_BAP_ASCS_RSP_CODE_CAP_UNSUPPORTED</ref></para>
</listitem><listitem><para><ref refid="group__bt__bap_1gga9f7efa749c75edd32dc50503397ab9d1a9676a2e7fc5e417cbae2cea663204ccb" kindref="member">BT_BAP_ASCS_RSP_CODE_NO_MEM</ref></para>
</listitem><listitem><para><ref refid="group__bt__bap_1gga9f7efa749c75edd32dc50503397ab9d1ac6c03bd8827040ce48905c58ea7d423a" kindref="member">BT_BAP_ASCS_RSP_CODE_UNSPECIFIED</ref> only value <ref refid="group__bt__bap_1gga9ca1630544a336b15af8a8e8934c5a45a1d4794f987bab3c784955ac10e1cdcdd" kindref="member">BT_BAP_ASCS_REASON_NONE</ref> shall be used. </para>
</listitem></itemizedlist>
</para>
        </detaileddescription>

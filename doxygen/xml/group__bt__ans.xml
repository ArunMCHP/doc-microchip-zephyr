        <type>int</type>
        <definition>int bt_ans_set_unread_count</definition>
        <argsstring>(struct bt_conn *conn, enum bt_ans_cat category, uint8_t unread)</argsstring>
        <name>bt_ans_set_unread_count</name>
        <param>
          <type>struct <ref refid="structbt__conn" kindref="compound">bt_conn</ref> *</type>
          <declname>conn</declname>
        </param>
        <param>
          <type>enum <ref refid="group__bt__ans_1gad25bb27a24ce597a574ed5f40378c259" kindref="member">bt_ans_cat</ref></type>

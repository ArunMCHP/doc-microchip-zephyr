        <briefdescription>
<para>Pin configuration bit field. </para>
        </briefdescription>
        <detaileddescription>
<para>Set mask to 0 for fixed pins (XSPI)</para>
<para>Fields:</para>
<para><itemizedlist>
<listitem><para>ctrl [ 0 : 2 ]</para>
</listitem><listitem><para>bit [ 3 : 7 ]</para>
</listitem><listitem><para>mode [ 8 : 10 ]</para>
</listitem><listitem><para>mask [ 11 : 14 ]</para>
</listitem><listitem><para>reg [ 16 : 23 ]</para>
</listitem><listitem><para>cfg [ 24 : 31 ]</para>
</listitem></itemizedlist>
</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>ctrl</parametername>
</parameternamelist>
<parameterdescription>
<para>Controller (0 = Global, 1 = AON-Main, 2 = LPS_Gear1, 3 = SWIRE) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>bit</parametername>
</parameternamelist>
<parameterdescription>
<para>Bit offset inside register (0..27) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>mode</parametername>
</parameternamelist>
<parameterdescription>
<para>Muxing option (0..7) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>mask</parametername>
</parameternamelist>
<parameterdescription>
<para>Bit mask for muxing option (1..7) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>reg</parametername>
</parameternamelist>
<parameterdescription>
<para>Register offset relative to pinmux base address (0..255) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>cfg</parametername>
</parameternamelist>
<parameterdescription>
<para>Register offset relative to pincfg base address (0..255) </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>

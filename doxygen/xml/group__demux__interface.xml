        <type>int</type>
        <definition>int devmux_select_set</definition>
        <argsstring>(struct device *dev, size_t index)</argsstring>
        <name>devmux_select_set</name>
        <param>
          <type>struct <ref refid="structdevice" kindref="compound">device</ref> *</type>
          <declname>dev</declname>
        </param>

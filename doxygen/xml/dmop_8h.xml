        <type>int</type>
        <definition>int dmop_create_ioreq_server</definition>
        <argsstring>(domid_t domid, uint8_t handle_bufioreq, ioservid_t *id)</argsstring>
        <name>dmop_create_ioreq_server</name>
        <param>
          <type><ref refid="xen_8h_1a52133e9b6faf803a509868928d1c0eee" kindref="member">domid_t</ref></type>
          <declname>domid</declname>
        </param>
        <param>
          <type><ref refid="stdint_8h_1a3cb4a16b0e8d6af0af86d4fd6ba5fd9d" kindref="member">uint8_t</ref></type>

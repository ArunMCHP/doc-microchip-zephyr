        <briefdescription>
<para>Transforms the data of an ITS entry for storage. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">uid</parametername>
</parameternamelist>
<parameterdescription>
<para>The entry&apos;s UID. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">data_len</parametername>
</parameternamelist>
<parameterdescription>
<para>The number of bytes in <computeroutput>data</computeroutput>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">data</parametername>
</parameternamelist>
<parameterdescription>
<para>The data to transform for storage. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">create_flags</parametername>
</parameternamelist>
<parameterdescription>
<para>The entry&apos;s create flags. It must contain only valid <computeroutput>PSA_STORAGE_FLAG_*</computeroutput> values. It gets stored as part of <computeroutput>stored_data</computeroutput>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">stored_data</parametername>
</parameternamelist>
<parameterdescription>
<para>The buffer to which the transformed data is written. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">stored_data_len</parametername>
</parameternamelist>
<parameterdescription>
<para>On success, the number of bytes written to <computeroutput>stored_data</computeroutput>.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><computeroutput>PSA_SUCCESS</computeroutput> on success, anything else on failure. </para>
</simplesect>
</para>

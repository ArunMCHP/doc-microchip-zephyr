</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>g_idx</parametername>
</parameternamelist>
<parameterdescription>
<para>group index </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>pin number </para>
</simplesect>
</para>

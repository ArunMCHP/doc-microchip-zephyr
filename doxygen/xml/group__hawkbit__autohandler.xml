        <argsstring>(void)</argsstring>
        <name>hawkbit_autohandler_cancel</name>
        <param>
          <type>void</type>
        </param>
        <briefdescription>
<para>Cancel the run of the hawkBit autohandler. </para>
        </briefdescription>
        <detaileddescription>
<para><simplesect kind="return"><para>a value from <ref refid="group__workqueue__apis_1ga92355914ee178d4c3e848a1946bed3e4" kindref="member">k_work_cancel_delayable()</ref>. </para>
</simplesect>
</para>

    <sectiondef kind="func">
      <memberdef kind="function" id="group__bt__att_1gad2305f28744276d97aefd26bdb79023c" prot="public" static="yes" const="no" explicit="no" inline="yes" virt="non-virtual">
        <type>const char *</type>
        <definition>static const char * bt_att_err_to_str</definition>
        <argsstring>(uint8_t att_err)</argsstring>
        <name>bt_att_err_to_str</name>
        <param>
          <type><ref refid="stdint_8h_1a3cb4a16b0e8d6af0af86d4fd6ba5fd9d" kindref="member">uint8_t</ref></type>
          <declname>att_err</declname>
        </param>
        <briefdescription>
<para>Converts a ATT error to string. </para>
        </briefdescription>
        <detaileddescription>
<para>The error codes are described in the Bluetooth Core specification, Vol 3, Part F, Section 3.4.1.1 and in The Supplement to the Bluetooth Core Specification (CSS), v11, Part B, Section 1.2.</para>
<para>The ATT and GATT documentation found in Vol 4, Part F and Part G describe when the different error codes are used.</para>
<para>See also the defined BT_ATT_ERR_* macros.</para>
<para><simplesect kind="return"><para>The string representation of the ATT error code. If <computeroutput>CONFIG_BT_ATT_ERR_TO_STR</computeroutput> is not enabled, this just returns the empty string </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/bluetooth/att.h" line="127" column="26" bodyfile="zephyr/bluetooth/att.h" bodystart="127" bodyend="132"/>
      </memberdef>
      <memberdef kind="function" id="group__bt__att_1ga748194cbbd54a3336d3c788f08e3de99" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int bt_eatt_connect</definition>
        <argsstring>(struct bt_conn *conn, size_t num_channels)</argsstring>
        <name>bt_eatt_connect</name>
        <param>
          <type>struct <ref refid="structbt__conn" kindref="compound">bt_conn</ref> *</type>
          <declname>conn</declname>
        </param>
        <param>
          <type><ref refid="retained__mem_8h_1a36713c339c3c5ec6d6bd481480bdb6f9" kindref="member">size_t</ref></type>
          <declname>num_channels</declname>
        </param>
        <briefdescription>
<para>Connect Enhanced ATT channels. </para>
        </briefdescription>
        <detaileddescription>
<para>Sends a series of Credit Based Connection Requests to connect <computeroutput>num_channels</computeroutput> Enhanced ATT channels. The peer may have limited resources and fewer channels may be created.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>conn</parametername>
</parameternamelist>
<parameterdescription>
<para>The connection to send the request on </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>num_channels</parametername>
</parameternamelist>
<parameterdescription>
<para>The number of Enhanced ATT bearers to request. Must be in the range 1 - <computeroutput>CONFIG_BT_EATT_MAX</computeroutput>, inclusive.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 in case of success or negative value in case of error. </para>
</simplesect>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>-EINVAL</parametername>
</parameternamelist>
<parameterdescription>
<para>if <computeroutput>num_channels</computeroutput> is not in the allowed range or <computeroutput>conn</computeroutput> is NULL. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-ENOMEM</parametername>
</parameternamelist>
<parameterdescription>
<para>if less than <computeroutput>num_channels</computeroutput> are allocated. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>in case of success </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/bluetooth/att.h" line="160" column="5" declfile="zephyr/bluetooth/att.h" declline="160" declcolumn="5"/>
      </memberdef>

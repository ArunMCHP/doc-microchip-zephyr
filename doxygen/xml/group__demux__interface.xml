        <definition>int devmux_select_get</definition>
        <argsstring>(const struct device *dev)</argsstring>
        <name>devmux_select_get</name>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *</type>
          <declname>dev</declname>
        </param>
        <briefdescription>
<para>Get the current selection of a devmux device. </para>
        </briefdescription>
        <detaileddescription>
<para>Return the index of the currently selected device.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>dev</parametername>
</parameternamelist>
<parameterdescription>
<para>the devmux device </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>The index (&gt;= 0) of the currently active multiplexed device on success </para>
</simplesect>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>-EINVAL</parametername>
</parameternamelist>
<parameterdescription>
<para>If <computeroutput>dev</computeroutput> is invalid </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>

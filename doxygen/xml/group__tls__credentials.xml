    <sectiondef kind="typedef">
      <memberdef kind="typedef" id="group__tls__credentials_1gaadfe9694309e473f7be74ed98dfb36d3" prot="public" static="no">
        <type>int</type>
        <definition>typedef int sec_tag_t</definition>
        <argsstring></argsstring>
        <name>sec_tag_t</name>
        <briefdescription>
<para>Secure tag, a reference to TLS credential. </para>
        </briefdescription>
        <detaileddescription>
<para>Secure tag can be used to reference credential after it was registered in the system.</para>
<para><simplesect kind="note"><para>Some TLS credentials come in pairs:<itemizedlist>
<listitem><para>TLS_CREDENTIAL_PUBLIC_CERTIFICATE with TLS_CREDENTIAL_PRIVATE_KEY,</para>
</listitem><listitem><para>TLS_CREDENTIAL_PSK with TLS_CREDENTIAL_PSK_ID. Such pairs of credentials should generally be assigned the same secure tag when used with subsystems that support fetching multiple credentials per tag, such as TLS sockets. However, note that certain subsystems or implementations may expect only one credential per secure tag.</para>
</listitem></itemizedlist>
</para>
</simplesect>
<simplesect kind="note"><para>Negative values are reserved for internal use. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/net/tls_credentials.h" line="80" column="13" bodyfile="zephyr/net/tls_credentials.h" bodystart="80" bodyend="-1"/>
      </memberdef>
    </sectiondef>
    <sectiondef kind="func">
      <memberdef kind="function" id="group__tls__credentials_1ga640ff6dd3eb4d5017feaab6fab2bb2f7" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int tls_credential_add</definition>
        <argsstring>(sec_tag_t tag, enum tls_credential_type type, const void *cred, size_t credlen)</argsstring>
        <name>tls_credential_add</name>
        <param>
          <type><ref refid="group__tls__credentials_1gaadfe9694309e473f7be74ed98dfb36d3" kindref="member">sec_tag_t</ref></type>
          <declname>tag</declname>
        </param>
        <param>
          <type>enum <ref refid="group__tls__credentials_1ga3a754894d0162634b59d60e319f37cd5" kindref="member">tls_credential_type</ref></type>
          <declname>type</declname>
        </param>
        <param>
          <type>const void *</type>
          <declname>cred</declname>
        </param>
        <param>
          <type><ref refid="retained__mem_8h_1a36713c339c3c5ec6d6bd481480bdb6f9" kindref="member">size_t</ref></type>
          <declname>credlen</declname>
        </param>
        <briefdescription>
<para>Add a TLS credential. </para>
        </briefdescription>
        <detaileddescription>
<para>This function adds a TLS credential, that can be used by TLS/DTLS for authentication.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>tag</parametername>
</parameternamelist>
<parameterdescription>
<para>A security tag that credential will be referenced with. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>type</parametername>
</parameternamelist>
<parameterdescription>
<para>A TLS/DTLS credential type. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>cred</parametername>
</parameternamelist>
<parameterdescription>
<para>A TLS/DTLS credential. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>credlen</parametername>
</parameternamelist>
<parameterdescription>
<para>A TLS/DTLS credential length.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>TLS credential successfully added. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EACCES</parametername>
</parameternamelist>
<parameterdescription>
<para>Access to the TLS credential subsystem was denied. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-ENOMEM</parametername>
</parameternamelist>
<parameterdescription>
<para>Not enough memory to add new TLS credential. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EEXIST</parametername>
</parameternamelist>
<parameterdescription>
<para>TLS credential of specific tag and type already exists. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/net/tls_credentials.h" line="100" column="5" declfile="zephyr/net/tls_credentials.h" declline="100" declcolumn="5"/>

  <compounddef id="group__bt__tmap" kind="group">
    <compoundname>bt_tmap</compoundname>
    <title>Telephone and Media Audio Profile (TMAP)</title>
    <innerclass refid="structbt__tmap__cb" prot="public">bt_tmap_cb</innerclass>
    <sectiondef kind="enum">
      <memberdef kind="enum" id="group__bt__tmap_1ga4ef8a550bb374a5f257860082e1411d4" prot="public" static="no" strong="no">
        <type></type>
        <name>bt_tmap_role</name>
        <enumvalue id="group__bt__tmap_1gga4ef8a550bb374a5f257860082e1411d4a7262b5c3d711c49afc29aceea3e41ff6" prot="public">
          <name>BT_TMAP_ROLE_CG</name>
          <initializer>= BIT(0)</initializer>
          <briefdescription>
<para>TMAP Call Gateway role. </para>
          </briefdescription>
          <detaileddescription>
<para>This role is defined to telephone and VoIP applications using the Call Control Profile to control calls on a remote TMAP Call Terminal. Audio streams in this role are typically bi-directional. </para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__bt__tmap_1gga4ef8a550bb374a5f257860082e1411d4ac09b686e750538387aa267d0161e177d" prot="public">
          <name>BT_TMAP_ROLE_CT</name>
          <initializer>= BIT(1)</initializer>
          <briefdescription>
<para>TMAP Call Terminal role. </para>
          </briefdescription>
          <detaileddescription>
<para>This role is defined to telephone and VoIP applications using the Call Control Profile to expose calls to remote TMAP Call Gateways. Audio streams in this role are typically bi-directional. </para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__bt__tmap_1gga4ef8a550bb374a5f257860082e1411d4a60e70c130c36e95cb2f35e2d4bcd3501" prot="public">
          <name>BT_TMAP_ROLE_UMS</name>
          <initializer>= BIT(2)</initializer>
          <briefdescription>
<para>TMAP Unicast Media Sender role. </para>
          </briefdescription>
          <detaileddescription>
<para>This role is defined send media audio to TMAP Unicast Media Receivers. Audio streams in this role are typically uni-directional. </para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__bt__tmap_1gga4ef8a550bb374a5f257860082e1411d4a0fe256733164b603c2e9c8c4d8a04b22" prot="public">
          <name>BT_TMAP_ROLE_UMR</name>
          <initializer>= BIT(3)</initializer>
          <briefdescription>
<para>TMAP Unicast Media Receiver role. </para>
          </briefdescription>
          <detaileddescription>
<para>This role is defined receive media audio to TMAP Unicast Media Senders. Audio streams in this role are typically uni-directional. </para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__bt__tmap_1gga4ef8a550bb374a5f257860082e1411d4ab7c4fae3617cd88f9ca8e1f2cbfb7308" prot="public">
          <name>BT_TMAP_ROLE_BMS</name>
          <initializer>= BIT(4)</initializer>
          <briefdescription>
<para>TMAP Broadcast Media Sender role. </para>
          </briefdescription>
          <detaileddescription>
<para>This role is defined send media audio to TMAP Broadcast Media Receivers. Audio streams in this role are always uni-directional. </para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group__bt__tmap_1gga4ef8a550bb374a5f257860082e1411d4aefc5a62198ea9c09ebb189544d1478e8" prot="public">
          <name>BT_TMAP_ROLE_BMR</name>
          <initializer>= BIT(5)</initializer>
          <briefdescription>
<para>TMAP Broadcast Media Receiver role. </para>
          </briefdescription>
          <detaileddescription>
<para>This role is defined send media audio to TMAP Broadcast Media Senders. Audio streams in this role are always uni-directional. </para>
          </detaileddescription>
        </enumvalue>
        <briefdescription>
<para>TMAP Role characteristic. </para>
        </briefdescription>
        <detaileddescription>
        </detaileddescription>

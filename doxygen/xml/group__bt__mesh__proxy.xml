      <memberdef kind="function" id="group__bt__mesh__proxy_1ga9a72515992af4f93a34a6c1aaf69d8df" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int bt_mesh_proxy_solicit</definition>
        <argsstring>(uint16_t net_idx)</argsstring>
        <name>bt_mesh_proxy_solicit</name>
        <param>
          <type><ref refid="stdint_8h_1a5debae8b2a1ec20a6694c0c443ee399e" kindref="member">uint16_t</ref></type>
          <declname>net_idx</declname>
        </param>
        <briefdescription>
<para>Schedule advertising of Solicitation PDUs. </para>
        </briefdescription>
        <detaileddescription>
<para>Once called, the device will schedule advertising Solicitation PDUs for the amount of time defined by <computeroutput>adv_int</computeroutput> * (<computeroutput>CONFIG_BT_MESH_SOL_ADV_XMIT</computeroutput> + 1), where <computeroutput>adv_int</computeroutput> is 20ms for Bluetooth v5.0 or higher, or 100ms otherwise.</para>
<para>If the number of advertised Solicitation PDUs reached 0xFFFFFF, the advertisements will no longer be started until the node is reprovisioned.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>net_idx</parametername>
</parameternamelist>
<parameterdescription>
<para>Network Key Index</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success, or (negative) error code on failure. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

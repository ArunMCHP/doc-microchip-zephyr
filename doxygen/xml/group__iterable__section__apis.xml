</parameternamelist>
<parameterdescription>
<para>data type of section </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">secname</parametername>
</parameternamelist>
<parameterdescription>
<para>name of output section </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/sys/iterable_sections.h" line="92" column="9" bodyfile="zephyr/sys/iterable_sections.h" bodystart="92" bodyend="93"/>

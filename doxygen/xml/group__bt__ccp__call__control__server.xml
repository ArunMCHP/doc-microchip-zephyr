<parameterdescription>
<para>Pointer to a buffer of size <ref refid="group__bt__tbs_1ga42b72d7aef36cc7ea0d5dd4ec3d7a717" kindref="member">BT_TBS_MAX_UCI_SIZE</ref> that the bearer UCI will be written to.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>Success </para>
</parameterdescription>
</parameteritem>
<parameteritem>

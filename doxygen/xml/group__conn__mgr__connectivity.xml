    <sectiondef kind="func">
      <memberdef kind="function" id="group__conn__mgr__connectivity_1ga575d367c95592fd9f4ead694ff94543f" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int conn_mgr_if_connect</definition>
        <argsstring>(struct net_if *iface)</argsstring>
        <name>conn_mgr_if_connect</name>
        <param>
          <type>struct <ref refid="structnet__if" kindref="compound">net_if</ref> *</type>
          <declname>iface</declname>
        </param>
        <briefdescription>
<para>Connect interface. </para>
        </briefdescription>
        <detaileddescription>
<para>If the provided iface has been bound to a connectivity implementation, initiate network connect/association.</para>
<para>Automatically takes the iface admin-up (by calling <ref refid="group__net__if_1ga02644cc623fc7a8878c17d54984e4210" kindref="member">net_if_up</ref>) if it isn&apos;t already.</para>
<para>Non-Blocking.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>iface</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to network interface </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>on success. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-ESHUTDOWN</parametername>
</parameternamelist>
<parameterdescription>
<para>if the iface is not admin-up. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-ENOTSUP</parametername>
</parameternamelist>
<parameterdescription>
<para>if the iface does not have a connectivity implementation. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>implementation-specific status code otherwise. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/net/conn_mgr_connectivity.h" line="143" column="5" declfile="zephyr/net/conn_mgr_connectivity.h" declline="143" declcolumn="5"/>
      </memberdef>
      <memberdef kind="function" id="group__conn__mgr__connectivity_1gada2b5271b3e5dbcab629e1538b3d8eb4" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int conn_mgr_if_disconnect</definition>
        <argsstring>(struct net_if *iface)</argsstring>
        <name>conn_mgr_if_disconnect</name>
        <param>
          <type>struct <ref refid="structnet__if" kindref="compound">net_if</ref> *</type>
          <declname>iface</declname>
        </param>
        <briefdescription>
<para>Disconnect interface. </para>
        </briefdescription>
        <detaileddescription>
<para>If the provided iface has been bound to a connectivity implementation, disconnect/disassociate it from the network, and cancel any pending attempts to connect/associate.</para>
<para>Does nothing if the iface is currently admin-down.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>iface</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to network interface</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>on success. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-ENOTSUP</parametername>
</parameternamelist>
<parameterdescription>
<para>if the iface does not have a connectivity implementation. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>implementation-specific status code otherwise. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="zephyr/net/conn_mgr_connectivity.h" line="159" column="5" declfile="zephyr/net/conn_mgr_connectivity.h" declline="159" declcolumn="5"/>
      </memberdef>

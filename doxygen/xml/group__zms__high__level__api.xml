        <definition>ssize_t zms_get_data_length</definition>
        <argsstring>(struct zms_fs *fs, zms_id_t id)</argsstring>
        <name>zms_get_data_length</name>
        <param>
          <type>struct <ref refid="structzms__fs" kindref="compound">zms_fs</ref> *</type>
          <declname>fs</declname>
        </param>
        <param>
          <type><ref refid="group__zms__high__level__api_1ga0509b3dce3030a56ecff866d693944f9" kindref="member">zms_id_t</ref></type>
          <declname>id</declname>
        </param>
        <briefdescription>
<para>Gets the length of the data that is stored in an entry with a given <computeroutput>id</computeroutput> </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>fs</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the file system. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>id</parametername>
</parameternamelist>
<parameterdescription>
<para>ID of the entry whose data length to retrieve.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>Data length contained in the ATE. On success, it will be equal to the number of bytes in the ATE. On error, returns negative value of error codes defined in <computeroutput><ref refid="errno_8h" kindref="compound">errno.h</ref></computeroutput>. </para>
</simplesect>
<simplesect kind="return"><para>Length of the entry with the given <computeroutput>id</computeroutput> (&gt; 0) on success. </para>
</simplesect>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>-EACCES</parametername>
</parameternamelist>
<parameterdescription>
<para>if ZMS is still not initialized. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EIO</parametername>
</parameternamelist>
<parameterdescription>
<para>if there is a memory read/write error. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-ENOENT</parametername>
</parameternamelist>
<parameterdescription>
<para>if there is no entry with the given id. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EINVAL</parametername>
</parameternamelist>
<parameterdescription>
<para>if <computeroutput>fs</computeroutput> is NULL. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>

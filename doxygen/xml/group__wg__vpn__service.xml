        <type>int</type>
        <definition>int wireguard_peer_add</definition>
        <argsstring>(struct wireguard_peer_config *peer_config, struct net_if **peer_iface)</argsstring>
        <name>wireguard_peer_add</name>
        <param>
          <type>struct <ref refid="structwireguard__peer__config" kindref="compound">wireguard_peer_config</ref> *</type>
          <declname>peer_config</declname>
        </param>

    <compoundname>spsc_buf</compoundname>
    <title>SPSC (Single producer, single consumer) packet buffer API</title>
    <innerclass refid="structspsc__pbuf__common" prot="public">spsc_pbuf_common</innerclass>
    <innerclass refid="structspsc__pbuf__ext__cache" prot="public">spsc_pbuf_ext_cache</innerclass>

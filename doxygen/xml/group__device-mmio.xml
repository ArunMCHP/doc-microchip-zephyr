          <type><ref refid="retained__mem_8h_1a36713c339c3c5ec6d6bd481480bdb6f9" kindref="member">size_t</ref></type>
          <declname>size</declname>
        </param>
        <briefdescription>
<para>Un-set linear address for device MMIO access. </para>
        </briefdescription>
        <detaileddescription>
<para>If the MMU is enabled, mappings can be removed from the page tables.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>virt_addr</parametername>
</parameternamelist>
<parameterdescription>
<para>Linear address obtained from <ref refid="group__device-mmio_1ga6b4a9841a5176104e1b63f7475d3d2a2" kindref="member">device_map</ref> </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>size</parametername>
</parameternamelist>
<parameterdescription>
<para>Size of the MMIO region </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>

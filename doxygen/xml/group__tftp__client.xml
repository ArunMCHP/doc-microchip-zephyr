</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>remote_file</parametername>
</parameternamelist>
<parameterdescription>
<para>Name of the remote file to put. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>mode</parametername>
</parameternamelist>

</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EINVAL</parametername>
</parameternamelist>
<parameterdescription>
<para>if the interrupt control operation fails. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>

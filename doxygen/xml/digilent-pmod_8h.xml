      <memberdef kind="define" id="digilent-pmod_8h_1acdb27a6e2e72f1092d49f49f356bd43d" prot="public" static="no">
        <name>PMOD_IO</name>
        <param><defname>n</defname></param>
        <initializer>((n) - 1)</initializer>
        <briefdescription>
<para>For reference see the Pmod interface specification: <ulink url="https://digilent.com/reference/_media/reference/pmod/pmod-interface-specification-1_2_0.pdf">https://digilent.com/reference/_media/reference/pmod/pmod-interface-specification-1_2_0.pdf</ulink>. </para>

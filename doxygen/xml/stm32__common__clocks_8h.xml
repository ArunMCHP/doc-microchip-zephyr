        <initializer>	((((reg) &amp; <ref refid="stm32__common__clocks_8h_1a9ad0be6cd421f8b608f74a3676bf9d6d" kindref="member">STM32_DT_CLKSEL_REG_MASK</ref>) &lt;&lt; <ref refid="stm32__common__clocks_8h_1a007f65a597867a03a6dc9b1e73d27a2d" kindref="member">STM32_DT_CLKSEL_REG_SHIFT</ref>) |			\

<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>0</parametername>
</parameternamelist>
<parameterdescription>
<para>If a valid index is found within linear range. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-ERANGE</parametername>
</parameternamelist>
<parameterdescription>
<para>If the given window of values falls partially out of the linear range. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>-EINVAL</parametername>
</parameternamelist>
<parameterdescription>
<para>If the given window of values does not intersect with the linear range or if they are too narrow. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>

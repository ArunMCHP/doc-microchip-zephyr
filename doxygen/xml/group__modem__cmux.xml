      <memberdef kind="function" id="group__modem__cmux_1gadc7c6ff92b7ac52717151bd6bf1efdff" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void modem_cmux_release</definition>
        <argsstring>(struct modem_cmux *cmux)</argsstring>
        <name>modem_cmux_release</name>
        <param>
          <type>struct modem_cmux *</type>
          <declname>cmux</declname>
        </param>
        <briefdescription>
<para>Release CMUX instance from pipe. </para>
        </briefdescription>
        <detaileddescription>
<para>Releases the pipe and hard resets the CMUX instance internally. CMUX should be disconnected using <ref refid="group__modem__cmux_1ga482171f67db206780d0b8a2cf5b32a93" kindref="member">modem_cmux_disconnect()</ref>.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>cmux</parametername>
</parameternamelist>
<parameterdescription>
<para>CMUX instance</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="note"><para>The bus pipe can be used directly again after CMUX instance is released. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

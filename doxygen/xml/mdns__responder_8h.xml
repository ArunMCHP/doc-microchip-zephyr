      <memberdef kind="function" id="mdns__responder_8h_1a4682ee30bf3e739790dbcaede5485777" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int mdns_responder_set_ext_records</definition>
        <argsstring>(const struct dns_sd_rec *records, size_t count)</argsstring>
        <name>mdns_responder_set_ext_records</name>
        <param>
          <type>const struct <ref refid="structdns__sd__rec" kindref="compound">dns_sd_rec</ref> *</type>
          <declname>records</declname>
        </param>
        <param>
          <type><ref refid="retained__mem_8h_1a36713c339c3c5ec6d6bd481480bdb6f9" kindref="member">size_t</ref></type>
          <declname>count</declname>
        </param>
        <briefdescription>
<para>Register continuous memory of <ref refid="structdns__sd__rec" kindref="compound">dns_sd_rec</ref> records. </para>
        </briefdescription>
        <detaileddescription>
<para>mDNS responder will start with iteration over mDNS records registered using <ref refid="group__dns__sd_1ga0c0060a680d5c4fe56f2815c920c3627" kindref="member">DNS_SD_REGISTER_SERVICE</ref> (if any) and then go over external records.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>records</parametername>
</parameternamelist>
<parameterdescription>
<para>A pointer to an array of mDNS records. It is stored internally without copying the content so it must be kept valid. It can be set to NULL, e.g. before freeing the memory block. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>count</parametername>
</parameternamelist>
<parameterdescription>
<para>The number of elements </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 for OK; -EINVAL for invalid parameters. </para>
</simplesect>
</para>
        </detaileddescription>

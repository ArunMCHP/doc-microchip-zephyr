        <type>__boot_func void</type>
        <definition>static __boot_func void device_unmap</definition>
        <argsstring>(mm_reg_t virt_addr, size_t size)</argsstring>
        <name>device_unmap</name>
        <param>
          <type><ref refid="sys_2sys__io_8h_1a7bcfa789a44940bccc5b9b98642744b0" kindref="member">mm_reg_t</ref></type>

    <sectiondef kind="func">
      <memberdef kind="function" id="memory_8h_1ab548b9bcc4479f33f3d8b8467dc6855f" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int xendom_add_to_physmap</definition>
        <argsstring>(int domid, unsigned long idx, unsigned int space, xen_pfn_t gpfn)</argsstring>
        <name>xendom_add_to_physmap</name>
        <param>
          <type>int</type>
          <declname>domid</declname>
        </param>
        <param>
          <type><ref refid="lib_2libc_2minimal_2include_2sys_2types_8h_1a4089fb16419d359081465355db05f846" kindref="member">unsigned</ref> long</type>
          <declname>idx</declname>
        </param>
        <param>
          <type><ref refid="lib_2libc_2minimal_2include_2sys_2types_8h_1a4089fb16419d359081465355db05f846" kindref="member">unsigned</ref> int</type>
          <declname>space</declname>
        </param>
        <param>
          <type><ref refid="arch-arm_8h_1a564b8052e6905461f66db791246d2226" kindref="member">xen_pfn_t</ref></type>
          <declname>gpfn</declname>
        </param>
        <briefdescription>
<para>Add mapping for specified page frame in Xen domain physmap. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>domid</parametername>
</parameternamelist>
<parameterdescription>
<para>domain id, where mapping will be added. For unprivileged should be DOMID_SELF. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>idx</parametername>

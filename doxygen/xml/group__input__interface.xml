      <memberdef kind="define" id="group__input__interface_1gac986cdf392f9aa0a771c8e4e92c479a3" prot="public" static="no">
        <name>INPUT_CALLBACK_DEFINE</name>
        <param><defname>_dev</defname></param>
        <param><defname>_callback</defname></param>
        <param><defname>_user_data</defname></param>
        <initializer>	<ref refid="group__input__interface_1gad3e7310625b14db2e6930f66dfd879a7" kindref="member">INPUT_CALLBACK_DEFINE_NAMED</ref>(_dev, _callback, _user_data, _callback)</initializer>
        <briefdescription>
<para>Register a callback structure for input events. </para>
        </briefdescription>
        <detaileddescription>
<para>The <computeroutput>_dev</computeroutput> field can be used to only invoke callback for events generated by a specific device. Setting dev to NULL causes callback to be invoked for every event.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>_dev</parametername>
</parameternamelist>
<parameterdescription>
<para><ref refid="structdevice" kindref="compound">device</ref> pointer or NULL. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>_callback</parametername>
</parameternamelist>
<parameterdescription>
<para>The callback function. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>_user_data</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to user specified data. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

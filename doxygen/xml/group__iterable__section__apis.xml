      <memberdef kind="define" id="group__iterable__section__apis_1ga40c6ba05d5bcb848a530bdc17bbff5be" prot="public" static="no">
        <name>TYPE_SECTION_START_EXTERN</name>
        <param><defname>type</defname></param>
        <param><defname>secname</defname></param>
        <initializer>	extern type <ref refid="group__iterable__section__apis_1gac97b7f4fd42a2d9e11b6a585bc716a05" kindref="member">TYPE_SECTION_START</ref>(secname)[]</initializer>
        <briefdescription>

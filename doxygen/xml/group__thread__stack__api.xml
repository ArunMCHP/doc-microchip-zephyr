<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>sym</parametername>
</parameternamelist>
<parameterdescription>
<para>Thread stack symbol name </para>
</parameterdescription>
</parameteritem>
<parameteritem>

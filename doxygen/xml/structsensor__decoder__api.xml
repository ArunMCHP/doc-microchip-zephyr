      <memberdef kind="variable" id="structsensor__decoder__api_1a026be8086386e9eea0a1cb25c1cd602e" prot="public" static="no" mutable="no">
        <type>int(*</type>
        <definition>int(* sensor_decoder_api::get_size_info) (struct sensor_chan_spec channel, size_t *base_size, size_t *frame_size)</definition>
        <argsstring>)(struct sensor_chan_spec channel, size_t *base_size, size_t *frame_size)</argsstring>
        <name>get_size_info</name>
        <qualifiedname>sensor_decoder_api::get_size_info</qualifiedname>
        <briefdescription>
<para>Get the size required to decode a given channel. </para>
        </briefdescription>
        <detaileddescription>
<para>When decoding a single frame, use <computeroutput>base_size</computeroutput>. For every additional frame, add another <computeroutput>frame_size</computeroutput>. As an example, to decode 3 frames use: &apos;base_size + 2 * frame_size&apos;.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">channel</parametername>
</parameternamelist>
<parameterdescription>
<para>The channel to query </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">base_size</parametername>
</parameternamelist>
<parameterdescription>
<para>The size of decoding the first frame </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">frame_size</parametername>
</parameternamelist>
<parameterdescription>
<para>The additional size of every additional frame </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success </para>
</simplesect>
<simplesect kind="return"><para>-ENOTSUP if the channel is not supported </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

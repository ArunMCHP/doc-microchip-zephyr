      <memberdef kind="function" id="group__kernel__mm__internal__apis_1gaed8dccb2a3c15daff9d2e5b4d49f782a" prot="public" static="yes" const="no" explicit="no" inline="yes" virt="non-virtual">
        <type>void *</type>

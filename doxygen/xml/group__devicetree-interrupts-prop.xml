<parameterdescription>
<para>node identifier </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>idx</parametername>
</parameternamelist>
<parameterdescription>
<para>index to check </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>

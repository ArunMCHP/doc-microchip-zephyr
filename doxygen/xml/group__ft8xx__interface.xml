      <memberdef kind="function" id="group__ft8xx__interface_1ga1c9ade4374b9619c68efa11dd1a56eae" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type><ref refid="stdint_8h_1a0a8582351ac627ee8bde2973c825e47f" kindref="member">uint32_t</ref></type>
        <definition>uint32_t ft8xx_get_tracker_value</definition>
        <argsstring>(const struct device *dev)</argsstring>
        <name>ft8xx_get_tracker_value</name>
        <param>
          <type>const struct <ref refid="structdevice" kindref="compound">device</ref> *</type>
          <declname>dev</declname>
        </param>
        <briefdescription>
<para>Get the tag and the tracking value of the tracked object. </para>
        </briefdescription>
        <detaileddescription>
<para>The reported tag and the tracking value apply to an object tracked by the coprocessor with the <ref refid="group__ft8xx__copro_1gac946f044f2fbb6381ea4af268084d828" kindref="member">ft8xx_copro_cmd_track()</ref> function.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>dev</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the device structure for the driver instance</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>Track register content where 2 MS bytes (0xffff0000 mask) indicate the track value and 2 LS bytes (0x0000ffff mask) indicate the tag. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
